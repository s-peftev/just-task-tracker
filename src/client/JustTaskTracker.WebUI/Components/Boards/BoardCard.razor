@using JustTaskTracker.WebUI.Domain.Auth
@using JustTaskTracker.WebUI.Domain.Boards
@using JustTaskTracker.WebUI.Domain.Boards.Authorization
@using JustTaskTracker.WebUI.Domain.Boards.Enums
@inject ISnackbar Snackbar

<div class="board-card card-elevated @(Board.IsArchived ? "board-card--archived" : null)"
     role="button"
     tabindex="0"
     @onclick="OnClickHandler"
     @onkeydown="OnCardKeyDownAsync">
    <div class="board-card__body">
        @if (Board.IsArchived && CanViewBoardDownloadStatus)
        {
            @if (Board.BoardSerializationStatus == BoardSerializationStatus.Completed)
            {
                <button type="button"
                        class="board-card__corner-action board-card__corner-action--download"
                        aria-label="@DownloadTooltip"
                        @onclick="OnDownloadClick"
                        @onclick:stopPropagation="true">
                    <svg class="board-card__corner-icon"
                         viewBox="0 0 24 24"
                         aria-hidden="true"
                         focusable="false">
                        <path d="M20.54 5.23l-1.39-1.68C18.88 3.21 18.47 3 18 3H6c-.47 0-.88.21-1.16.55L3.46 5.23C3.17 5.57 3 6.02 3 6.5V19c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6.5c0-.48-.17-.93-.46-1.27zM12 17.5 6.5 12H10v-2h4v2h3.5L12 17.5zM5.12 5l.81-1h12l.94 1H5.12z"
                              fill="currentColor" />
                    </svg>
                    <span class="board-card__corner-tooltip" aria-hidden="true">@DownloadTooltip</span>
                </button>
            }
            else
            {
                <div class="board-card__corner-action board-card__corner-action--indicator">
                    <BoardSerializationStatusIndicator Status="Board.BoardSerializationStatus"
                                                       TooltipBelow="true" />
                </div>
            }
        }

        <p class="board-card__meta">
            <span class="board-card__meta-label">Board creator:</span>
            @OwnerDisplayName
        </p>
        <p class="board-card__meta">
            <span class="board-card__meta-label">Your role:</span>
            @Board.UserRole
        </p>
    </div>

    <div class="board-card__footer">
        <span class="board-card__name" title="@Board.Name">@Board.Name</span>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public BoardLookupDto Board { get; set; } = default!;

    [Parameter]
    public EventCallback<BoardLookupDto> OnClick { get; set; }

    private bool CanViewBoardDownloadStatus =>
        BoardRolePermissions.CanArchiveBoard(Board.UserRole);

    private static string DownloadTooltip =>
        BoardSerializationStatusFormatting.GetDescription(BoardSerializationStatus.Completed);

    private Task OnClickHandler() => OnClick.InvokeAsync(Board);

    private async Task OnCardKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key is "Enter" or " ")
            await OnClickHandler();
    }

    private void OnDownloadClick() =>
        Snackbar.Add("Board download is coming soon.", Severity.Info);

    private string OwnerDisplayName =>
        string.IsNullOrWhiteSpace(Board.OwnerEmail)
            ? "—"
            : UserDisplayFormatting.GetShortName(Board.OwnerDisplayName, Board.OwnerEmail);
}
