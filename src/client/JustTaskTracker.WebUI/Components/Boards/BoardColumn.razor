@using JustTaskTracker.WebUI.Domain.Boards
@using JustTaskTracker.WebUI.Domain.Boards.Enums
@using JustTaskTracker.WebUI.Domain.Boards.Authorization
@using JustTaskTracker.WebUI.Domain.Boards.Requests
@using JustTaskTracker.WebUI.Infrastructure
@using JustTaskTracker.WebUI.Components.Shared
@using JustTaskTracker.WebUI.Components.Shared.Forms
@using JustTaskTracker.WebUI.Services.Abstractions.Auth
@using JustTaskTracker.WebUI.Services.Abstractions.Boards
@using JustTaskTracker.WebUI.Services.Exceptions
@using BlazorSortable
@using Microsoft.JSInterop
@implements IDisposable
@inject IJSRuntime Js

<article class="board-column" data-column-id="@Column.Id">
    <header class="board-column__header @(CanReorderColumn ? "board-column__header--draggable" : null)">
        <div class="board-column__title-area">
            @if (_isEditingName)
            {
                <div class="board-column__title-field">
                    <span class="board-column__title-sizer">@_editName</span>
                    <input @ref="_titleInputRef"
                           class="board-column__title-input"
                           type="text"
                           maxlength="50"
                           @bind="_editName"
                           @bind:event="oninput"
                           @onkeydown="OnTitleKeyDownAsync"
                           @onblur="OnTitleBlurAsync" />
                </div>
            }
            else if (CanRenameColumn)
            {
                <h2 class="board-column__title board-column__title--editable"
                    title="@Column.Name"
                    @onpointerdown="OnTitlePointerDown"
                    @onpointerup="OnTitlePointerUp">
                    @Column.Name
                </h2>
            }
            else
            {
                <h2 class="board-column__title" title="@Column.Name">@Column.Name</h2>
            }
        </div>

        <div class="board-column__header-actions">
            <span class="board-column__count" aria-label="@GetCountAriaLabel()">
                <span class="board-column__count-mine"
                      title="Tasks assigned to you">@GetAssignedToMeTaskCount()</span>
                <span class="board-column__count-separator" aria-hidden="true">/</span>
                <span class="board-column__count-total"
                      title="Total tasks in this column">@GetTotalTaskCount()</span>
            </span>
            @if (CanDeleteColumn)
            {
                <button type="button"
                        class="btn-icon btn-icon--sm board-column__delete"
                        aria-label="Delete column"
                        @onclick="DeleteColumnAsync">
                    <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M18 6L6 18M6 6l12 12"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round" />
                    </svg>
                </button>
            }
        </div>
    </header>

    <div class="board-column__progress"
         title="@GetColumnShareTooltip()"
         role="meter"
         aria-valuemin="0"
         aria-valuemax="100"
         aria-valuenow="@GetColumnSharePercentRounded()"
         aria-label="@GetColumnShareTooltip()">
        <div class="board-column__progress-track">
            <div class="board-column__progress-fill"
                 style="--board-column-progress: @GetColumnSharePercentCss()"></div>
        </div>
    </div>

    <div @ref="_tasksListRef"
         class="board-column__tasks @(_hasTaskContent ? "board-column__tasks--filled" : null)">
        <Sortable TItem="BoardTaskPreviewDto"
                  @key="Column.Id"
                  Id="@Column.Id.ToString()"
                  Items="_sortableTasks"
                  ItemKeySelector="GetTaskKey"
                  Group="board-tasks"
                  PullMode="SortablePullMode.True"
                  PutMode="SortablePutMode.True"
                  Handle=".board-task-card--draggable"
                  Filter=".board-column__add-task-input"
                  Delay="0"
                  DelayOnTouchOnly="true"
                  FallbackTolerance="5"
                  Disabled="@(!CanMoveTasks || _isReorderingTasks || BoardDetailsStore.IsReorderingTasks)"
                  Class="board-column__tasks-sortable"
                  GhostClass="board-column__task-ghost"
                  DragClass="board-column__task-drag"
                  Scroll="false"
                  OnUpdate="OnTaskSortableChangedAsync"
                  OnAdd="OnTaskSortableChangedAsync">
            <div class="board-column__task-item">
                @if (IsTaskVisible(context))
                {
                    <BoardTaskCard Task="context"
                                   CanDrag="CanMoveTasks"
                                   IsAssignedToCurrentUser="@IsAssignedToCurrentUser(context)"
                                   OnTaskClick="OnTaskClickAsync" />
                }
            </div>
        </Sortable>
    </div>

    <footer class="board-column__footer @(!CanManageTasks ? "board-column__footer--spacer" : null)">
        @if (CanManageTasks)
        {
            @if (_isAddingTask)
            {
                <textarea @ref="_taskTitleInputRef"
                          class="board-column__add-task-input"
                          rows="2"
                          maxlength="50"
                          placeholder="Enter a task title"
                          @bind="_newTaskTitle"
                          @bind:event="oninput"
                          @onkeydown="OnTaskTitleKeyDownAsync"
                          @onblur="OnTaskTitleBlurAsync"></textarea>
            }
            else
            {
                <button type="button"
                        class="board-column__add-task"
                        @onclick="StartAddTask">
                    + Add task
                </button>
            }
        }
    </footer>
</article>

@code {
    private const int MaxNameLength = 50;
    private const int MaxTaskTitleLength = 50;
    private const double TitleClickMoveThresholdPx = 5;

    [Parameter, EditorRequired]
    public ColumnDto Column { get; set; } = default!;

    [Parameter, EditorRequired]
    public BoardMemberRole UserRole { get; set; }

    [Inject]
    private IBoardApiService BoardApiService { get; set; } = default!;

    [Inject]
    private IBoardDetailsStore BoardDetailsStore { get; set; } = default!;

    [Inject]
    private IProfileStore ProfileStore { get; set; } = default!;

    [Inject]
    private ISnackbar Snackbar { get; set; } = default!;

    [Inject]
    private IDialogService DialogService { get; set; } = default!;

    [Inject]
    private NavigationManager Navigation { get; set; } = default!;

    private bool _isEditingName;
    private bool _isSavingName;
    private bool _focusTitleInput;
    private string _editName = string.Empty;
    private ElementReference _titleInputRef;
    private double? _titlePointerDownX;
    private double? _titlePointerDownY;

    private bool _isAddingTask;
    private bool _isSavingTask;
    private bool _focusTaskTitleInput;
    private string _newTaskTitle = string.Empty;
    private ElementReference _taskTitleInputRef;
    private ElementReference _tasksListRef;
    private bool _scrollTasksToBottom;
    private bool _isReorderingTasks;
    private int _expectedTaskCountAfterCreate;
    private IJSObjectReference? _tasksScrollModule;
    private readonly List<BoardTaskPreviewDto> _sortableTasks = [];

    private bool CanRenameColumn =>
        !BoardDetailsStore.IsReadOnly && BoardRolePermissions.CanManageColumns(UserRole);

    private bool CanDeleteColumn =>
        !BoardDetailsStore.IsReadOnly && BoardRolePermissions.CanManageColumns(UserRole);

    private bool CanReorderColumn =>
        !BoardDetailsStore.IsReadOnly && BoardRolePermissions.CanManageColumns(UserRole);

    private bool CanManageTasks =>
        !BoardDetailsStore.IsReadOnly && BoardRolePermissions.CanManageTasks(UserRole);

    private bool CanMoveTasks =>
        !BoardDetailsStore.IsReadOnly && BoardRolePermissions.CanMoveTasks(UserRole);

    private bool _hasTaskContent => GetVisibleTaskCount() > 0;

    protected override void OnInitialized()
    {
        BoardDetailsStore.StateChanged += OnBoardStateChanged;
        ProfileStore.StateChanged += OnProfileStateChanged;
    }

    protected override void OnParametersSet()
    {
        if (ShouldSkipSortableSync())
            return;

        SyncSortableTasksFromColumn();
    }

    public void Dispose()
    {
        BoardDetailsStore.StateChanged -= OnBoardStateChanged;
        ProfileStore.StateChanged -= OnProfileStateChanged;
    }

    private void OnProfileStateChanged()
    {
        if (!ShouldSkipSortableSync())
            SyncSortableTasksFromColumn();

        _ = InvokeAsync(StateHasChanged);
    }

    private void OnBoardStateChanged()
    {
        if (BoardDetailsStore.IsReorderingTasks)
            return;

        _isReorderingTasks = false;

        if (!ShouldSkipSortableSync())
            SyncSortableTasksFromColumn();

        _ = InvokeAsync(StateHasChanged);
    }

    private bool ShouldSkipSortableSync() =>
        _isReorderingTasks || BoardDetailsStore.IsReorderingTasks;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusTitleInput)
        {
            _focusTitleInput = false;
            await _titleInputRef.FocusAsync();
        }

        if (_focusTaskTitleInput)
        {
            _focusTaskTitleInput = false;
            await _taskTitleInputRef.FocusAsync();
        }

        if (_scrollTasksToBottom && Column.BoardTasks.Count >= _expectedTaskCountAfterCreate)
        {
            _scrollTasksToBottom = false;
            _tasksScrollModule ??= await Js.InvokeAsync<IJSObjectReference>("import", "./js/boardColumnTasks.js");
            await _tasksScrollModule.InvokeVoidAsync("scrollToBottom", _tasksListRef);
        }
    }

    private void StartNameEdit()
    {
        if (!CanRenameColumn || _isEditingName)
            return;

        _editName = Column.Name;
        _isEditingName = true;
        _focusTitleInput = true;
    }

    private void OnTitlePointerDown(PointerEventArgs e)
    {
        _titlePointerDownX = e.ClientX;
        _titlePointerDownY = e.ClientY;
    }

    private void OnTitlePointerUp(PointerEventArgs e)
    {
        if (!CanRenameColumn || _isEditingName)
            return;

        if (_titlePointerDownX is not { } startX || _titlePointerDownY is not { } startY)
            return;

        _titlePointerDownX = null;
        _titlePointerDownY = null;

        var movedX = Math.Abs(e.ClientX - startX);
        var movedY = Math.Abs(e.ClientY - startY);

        if (movedX > TitleClickMoveThresholdPx || movedY > TitleClickMoveThresholdPx)
            return;

        StartNameEdit();
    }

    private void CancelNameEdit()
    {
        _isEditingName = false;
        _editName = Column.Name;
    }

    private async Task OnTitleKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SaveColumnNameAsync();
        else if (e.Key == "Escape")
            CancelNameEdit();
    }

    private async Task OnTitleBlurAsync()
    {
        if (!_isEditingName)
            return;

        await SaveColumnNameAsync();
    }

    private async Task SaveColumnNameAsync()
    {
        if (!_isEditingName || _isSavingName || BoardDetailsStore.BoardId is not { } boardId)
            return;

        var trimmedName = _editName.Trim();

        if (string.IsNullOrEmpty(trimmedName))
        {
            Snackbar.Add("Column name is required.", Severity.Error);
            return;
        }

        if (trimmedName.Length > MaxNameLength)
        {
            Snackbar.Add($"Column name must not exceed {MaxNameLength} characters.", Severity.Error);
            return;
        }

        if (string.Equals(trimmedName, Column.Name, StringComparison.Ordinal))
        {
            CancelNameEdit();
            return;
        }

        _isSavingName = true;

        try
        {
            await BoardApiService.UpdateColumnAsync(boardId, Column.Id, trimmedName);
            BoardDetailsStore.UpdateColumnName(Column.Id, trimmedName);
            _isEditingName = false;
            Snackbar.Add("Column updated.", Severity.Success);
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
        finally
        {
            _isSavingName = false;
        }
    }

    private async Task DeleteColumnAsync()
    {
        if (BoardDetailsStore.Board is null)
            return;

        var otherColumns = BoardDetailsStore.Board.Columns
            .Where(column => column.Id != Column.Id)
            .OrderBy(column => column.Position)
            .ToList();

        var dialog = await DialogService.ShowResourceFormAsync(
            "Delete column",
            "Delete",
            DeleteColumnForm.FormId,
            DeleteColumnForm.Render(Column, otherColumns),
            submitButtonClass: "btn-dialog-danger btn-dialog-action");

        var result = await dialog.Result;

        if (result is not { Canceled: false, Data: DeleteColumnRequest request })
            return;

        try
        {
            await BoardDetailsStore.DeleteColumnAsync(Column.Id, request);
            Snackbar.Add($"Column \"{Column.Name}\" deleted.", Severity.Success);
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
    }

    private void StartAddTask()
    {
        if (!CanManageTasks || _isAddingTask)
            return;

        _newTaskTitle = string.Empty;
        _isAddingTask = true;
        _focusTaskTitleInput = true;
    }

    private void CancelAddTask()
    {
        _isAddingTask = false;
        _newTaskTitle = string.Empty;
    }

    private async Task OnTaskTitleKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
        {
            await SaveTaskAsync();
        }
        else if (e.Key == "Escape")
        {
            CancelAddTask();
        }
    }

    private async Task OnTaskTitleBlurAsync()
    {
        if (!_isAddingTask || _isSavingTask)
            return;

        await SaveTaskAsync();
    }

    private async Task SaveTaskAsync()
    {
        if (!_isAddingTask || _isSavingTask)
            return;

        var trimmedTitle = _newTaskTitle.Trim();

        if (string.IsNullOrEmpty(trimmedTitle))
        {
            CancelAddTask();
            return;
        }

        if (trimmedTitle.Length > MaxTaskTitleLength)
        {
            Snackbar.Add($"Task title must not exceed {MaxTaskTitleLength} characters.", Severity.Error);
            return;
        }

        _isSavingTask = true;

        try
        {
            _expectedTaskCountAfterCreate = Column.BoardTasks.Count + 1;
            await BoardDetailsStore.CreateTaskAsync(Column.Id, trimmedTitle);
            SyncSortableTasksFromColumn();
            CancelAddTask();
            _scrollTasksToBottom = true;
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
            CancelAddTask();
        }
        finally
        {
            _isSavingTask = false;
        }
    }

    private void OnTaskClickAsync(BoardTaskPreviewDto task)
    {
        if (BoardDetailsStore.BoardId is not { } boardId)
            return;

        Navigation.NavigateTo(BoardTaskRoutes.GetTaskUrl(boardId, Column.Id, task.Id));
    }

    private static string GetTaskKey(BoardTaskPreviewDto task) => task.Id.ToString();

    private void SyncSortableTasksFromColumn()
    {
        var ordered = Column.BoardTasks
            .OrderBy(task => task.Position)
            .AsEnumerable();

        if (BoardDetailsStore.ShowOnlyMyTasks && ProfileStore.Profile is { } profile)
            ordered = ordered.Where(task => task.IsAssignedToCurrentUser(profile.Id));

        _sortableTasks.Clear();
        _sortableTasks.AddRange(ordered);
    }

    private int GetTotalTaskCount() => Column.BoardTasks.Count;

    private int GetBoardTaskCount() =>
        BoardDetailsStore.Board?.Columns.Sum(column => column.BoardTasks.Count) ?? 0;

    private double GetColumnSharePercent()
    {
        var boardTotal = GetBoardTaskCount();
        if (boardTotal <= 0)
            return 0;

        return 100d * GetTotalTaskCount() / boardTotal;
    }

    private int GetColumnSharePercentRounded() =>
        (int)Math.Round(GetColumnSharePercent(), MidpointRounding.AwayFromZero);

    private string GetColumnSharePercentCss() =>
        $"{GetColumnSharePercent().ToString("0.###", System.Globalization.CultureInfo.InvariantCulture)}%";

    private string GetColumnShareTooltip()
    {
        var columnTotal = GetTotalTaskCount();
        var boardTotal = GetBoardTaskCount();
        return $"{columnTotal} of {boardTotal} tasks on this board are in this column";
    }

    private int GetAssignedToMeTaskCount()
    {
        if (ProfileStore.Profile is not { } profile)
            return 0;

        return Column.BoardTasks.Count(task => task.IsAssignedToCurrentUser(profile.Id));
    }

    private int GetVisibleTaskCount()
    {
        if (!BoardDetailsStore.ShowOnlyMyTasks)
            return GetTotalTaskCount();

        return GetAssignedToMeTaskCount();
    }

    private string GetCountAriaLabel() =>
        $"{GetAssignedToMeTaskCount()} assigned to you, {GetTotalTaskCount()} total in this column";

    private bool IsTaskVisible(BoardTaskPreviewDto task)
    {
        if (!BoardDetailsStore.ShowOnlyMyTasks)
            return true;

        if (ProfileStore.Profile is not { } profile)
            return false;

        return task.IsAssignedToCurrentUser(profile.Id);
    }

    private bool IsAssignedToCurrentUser(BoardTaskPreviewDto task) =>
        ProfileStore.Profile is { } profile && task.IsAssignedToCurrentUser(profile.Id);

    private async Task OnTaskSortableChangedAsync(SortableEventArgs<BoardTaskPreviewDto> args)
    {
        if (!CanMoveTasks || _isReorderingTasks || BoardDetailsStore.IsReorderingTasks)
            return;

        if (args.Operation == SortableChangeOperation.Remove)
            return;

        if (args.Operation == SortableChangeOperation.Update && args.OldIndex == args.NewIndex)
            return;

        if (args.Operation == SortableChangeOperation.Add && args.From.Id == args.To.Id)
            return;

        _isReorderingTasks = true;

        try
        {
            await BoardDetailsStore.ReorderTaskAsync(args.Item.Id, Column.Id, args.NewIndex);
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
        finally
        {
            _isReorderingTasks = false;

            if (!BoardDetailsStore.IsReorderingTasks)
                SyncSortableTasksFromColumn();
        }
    }
}
