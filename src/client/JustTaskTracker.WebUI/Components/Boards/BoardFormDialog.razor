@using FluentValidation
@using JustTaskTracker.WebUI.Validation

<MudDialog>
    <DialogContent>
        <MudForm @ref="_form" Model="_model" Validation="ValidateValue" ValidationDelay="0">
            <MudTextField @bind-Value="_model.Name"
                          For="@(() => _model.Name)"
                          Immediate="true"
                          Label="Board name"
                          Variant="Variant.Outlined"
                          Counter="100"
                          MaxLength="100"
                          AutoFocus="true" />
        </MudForm>
    </DialogContent>
    <DialogActions>
        <MudButton Class="btn-glass" OnClick="Cancel">Cancel</MudButton>
        <MudButton Class="login-ms-btn" OnClick="SubmitAsync" Disabled="_isSubmitting">
            @SubmitLabel
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string SubmitLabel { get; set; } = "Save";

    [Parameter]
    public string? InitialName { get; set; }

    private readonly BoardFormModel _model = new();
    private readonly BoardFormModelValidator _validator = new();
    private MudForm _form = default!;
    private bool _isSubmitting;

    protected override void OnInitialized() =>
        _model.Name = InitialName ?? string.Empty;

    private async Task SubmitAsync()
    {
        await _form.Validate();

        if (!_form.IsValid)
            return;

        _isSubmitting = true;
        MudDialog.Close(DialogResult.Ok(_model.Name.Trim()));
    }

    private void Cancel() => MudDialog.Cancel();

    private Func<object, string, Task<IEnumerable<string>>> ValidateValue => async (model, propertyName) =>
    {
        var result = await _validator.ValidateAsync(
            ValidationContext<BoardFormModel>.CreateWithOptions((BoardFormModel)model, x => x.IncludeProperties(propertyName)));

        return result.IsValid
            ? []
            : result.Errors.Select(e => e.ErrorMessage);
    };
}
