@using JustTaskTracker.WebUI.Components.Shared
@using JustTaskTracker.WebUI.Components.Shared.Forms
@using JustTaskTracker.WebUI.Domain.Billing.Constants
@using JustTaskTracker.WebUI.Domain.Boards
@using JustTaskTracker.WebUI.Domain.Boards.Authorization
@using JustTaskTracker.WebUI.Domain.Boards.Enums
@using JustTaskTracker.WebUI.Infrastructure
@using JustTaskTracker.WebUI.Services.Abstractions.Billing
@using JustTaskTracker.WebUI.Services.Abstractions.Boards
@using JustTaskTracker.WebUI.Services.Abstractions.Calls
@using JustTaskTracker.WebUI.Services.Exceptions
@implements IDisposable
@inject IBoardApiService BoardApiService
@inject IBoardArchiveDownloadService BoardArchiveDownloadService
@inject IBoardDetailsStore BoardDetailsStore
@inject IBoardStore BoardStore
@inject IBoardMembersStore BoardMembersStore
@inject IEntitlementsStore EntitlementsStore
@inject ICallSessionStore CallSessionStore
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

@if (BoardDetailsStore.Board is { } board)
{
    <header class="board-page__header">
        <div class="board-page__title-area">
            @if (_isEditingName)
            {
                <div class="board-page__title-field">
                    <span class="board-page__title-sizer">@_editName</span>
                    <input @ref="_titleInputRef"
                           class="board-page__title-input"
                           type="text"
                           maxlength="100"
                           @bind="_editName"
                           @bind:event="oninput"
                           @onkeydown="OnTitleKeyDownAsync"
                           @onblur="OnTitleBlurAsync" />
                </div>
            }
            else if (CanRenameBoard)
            {
                <span role="heading"
                      aria-level="1"
                      class="@GetTitleClass(editable: true)"
                      @onclick="StartNameEdit">
                    @board.Name
                </span>
            }
            else
            {
                <span role="heading"
                      aria-level="1"
                      class="@GetTitleClass(editable: false)">@board.Name</span>
            }
        </div>

        <div class="board-page__controls">
            @if (board.IsArchived && board.ArchivedAtUtc is { } archivedAtUtc)
            {
                <p class="board-page__archived-notice">
                    This board was archived on @FormatArchivedAt(archivedAtUtc)<br />
                    Available in read-only mode.
                </p>
                @if (CanExportBoard && HasAnyExportUi(board))
                {
                    <div class="board-page__export-actions">
                        @if (ShowDownloadButton(board))
                        {
                            <div class="board-page__export-status">
                                <button type="button"
                                        class="board-page__download-btn btn-icon"
                                        aria-label="@DownloadAriaLabel"
                                        disabled="@_isDownloadingArchive"
                                        @onclick="DownloadArchiveAsync">
                                    <svg viewBox="0 0 24 24"
                                         aria-hidden="true"
                                         focusable="false">
                                        <path d="M20.54 5.23l-1.39-1.68C18.88 3.21 18.47 3 18 3H6c-.47 0-.88.21-1.16.55L3.46 5.23C3.17 5.57 3 6.02 3 6.5V19c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6.5c0-.48-.17-.93-.46-1.27zM12 17.5 6.5 12H10v-2h4v2h3.5L12 17.5zM5.12 5l.81-1h12l.94 1H5.12z"
                                              fill="currentColor" />
                                    </svg>
                                    <span class="board-page__download-tooltip" aria-hidden="true">
                                        <BoardDownloadCopyTooltip Status="BoardExportStatus.Completed"
                                                                  ExportOptions="board.ExportOptions" />
                                    </span>
                                </button>
                            </div>
                        }

                        @if (ShowReExportAction(board))
                        {
                            <div class="board-page__export-status">
                                <button type="button"
                                        class="board-page__re-export-btn btn-icon"
                                        aria-label="Create a new downloadable copy with different options"
                                        @onclick="ReExportBoardAsync">
                                    <svg viewBox="0 0 24 24"
                                         aria-hidden="true"
                                         focusable="false">
                                        <path d="M17.65 6.35A7.96 7.96 0 0 0 12 4c-4.42 0-7.99 3.58-7.99 8s3.57 8 7.99 8c3.73 0 6.84-2.55 7.73-6h-2.08A4.997 4.997 0 0 1 12 18c-3.31 0-6-2.69-6-6s2.69-6 6-6c1.66 0 3.14.69 4.22 1.78L13 11h7V4l-2.35 2.35z"
                                              fill="currentColor" />
                                    </svg>
                                </button>
                            </div>
                        }

                        @if (ShowReExportStatusIndicator(board))
                        {
                            <div class="board-page__export-status">
                                <BoardExportStatusIndicator Status="board.ReExportStatus"
                                                            ExportOptions="board.ReExportOptions"
                                                            TooltipBelow="true" />
                            </div>
                        }
                        else if (ShowExportStatusIndicator(board))
                        {
                            <div class="board-page__export-status">
                                <BoardExportStatusIndicator Status="board.BoardExportStatus"
                                                            ExportOptions="board.ExportOptions"
                                                            TooltipBelow="true" />
                            </div>
                        }
                    </div>
                }
            }

            <button type="button"
                    data-calls-toggle
                    class="board-page-header__calls-btn btn-icon"
                    aria-label="Video calls"
                    @onclick="ToggleCallsSidebarAsync">
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                    <path d="M6.62 10.79a15.05 15.05 0 0 0 6.59 6.59l2.2-2.2a1 1 0 0 1 1.02-.24c1.12.37 2.33.57 3.57.57a1 1 0 0 1 1 1V20a1 1 0 0 1-1 1C10.61 21 3 13.39 3 4a1 1 0 0 1 1-1h3.5a1 1 0 0 1 1 1c0 1.24.2 2.45.57 3.57a1 1 0 0 1-.25 1.02l-2.2 2.2z"
                          fill="currentColor" />
                </svg>
            </button>

            <BoardPageStats BoardId="BoardId" OnMembersClick="OpenMembersOverlayAsync" />

            <BoardPageMenu UserRole="board.UserRole"
                           OnMembersClick="OpenMembersOverlayAsync"
                           OnLeaveBoardClick="LeaveBoardAsync"
                           OnArchiveBoardClick="ArchiveBoardAsync"
                           OnDeleteBoardClick="DeleteBoardAsync" />
        </div>
    </header>
}

@code {
    [Parameter]
    public Guid BoardId { get; set; }

    private bool _isEditingName;
    private bool _isSavingName;
    private bool _isDownloadingArchive;
    private bool _focusTitleInput;
    private bool _isNameHighlighted;
    private int _nameHighlightToken;
    private string _editName = string.Empty;
    private ElementReference _titleInputRef;

    private bool CanRenameBoard =>
        !BoardDetailsStore.IsReadOnly
        && BoardDetailsStore.Board is { UserRole: var role }
        && BoardRolePermissions.CanRenameBoard(role);

    private bool CanExportBoard =>
        BoardDetailsStore.Board is { UserRole: var role }
        && BoardRolePermissions.CanExportBoard(role);

    private bool CanDownloadArchive =>
        EntitlementsStore.Can(Features.BoardArchiveDownload);

    private bool CanViewExportStatus =>
        EntitlementsStore.Can(Features.BoardExport);

    private bool CanReExport =>
        EntitlementsStore.Can(Features.BoardReExport);

    private static string FormatArchivedAt(DateTime archivedAtUtc) =>
        archivedAtUtc.ToLocalTime().ToString("g");

    private string DownloadAriaLabel =>
        BoardDetailsStore.Board is { ExportOptions: var exportOptions }
            ? BoardExportStatusFormatting.GetAriaLabel(BoardExportStatus.Completed, exportOptions)
            : BoardExportStatusFormatting.GetDescription(BoardExportStatus.Completed);

    private bool ShowDownloadButton(BoardDetailsDto board) =>
        CanDownloadArchive && ShowPreviousExportDownload(board);

    private bool ShowReExportAction(BoardDetailsDto board) =>
        CanReExport && ShowReExportButton(board);

    private bool ShowReExportStatusIndicator(BoardDetailsDto board) =>
        CanReExport && board.ReExportStatus != BoardExportStatus.None;

    private bool ShowExportStatusIndicator(BoardDetailsDto board) =>
        CanViewExportStatus
        && board.ReExportStatus == BoardExportStatus.None
        && board.BoardExportStatus != BoardExportStatus.Completed;

    private bool HasAnyExportUi(BoardDetailsDto board) =>
        ShowDownloadButton(board)
        || ShowReExportAction(board)
        || ShowReExportStatusIndicator(board)
        || ShowExportStatusIndicator(board);

    private static bool ShowPreviousExportDownload(BoardDetailsDto board) =>
        board.BoardExportStatus == BoardExportStatus.Completed
        && (board.ReExportStatus == BoardExportStatus.None
            || board.ReExportStatus == BoardExportStatus.Requested
            || board.ReExportStatus == BoardExportStatus.Pending);

    private static bool ShowReExportButton(BoardDetailsDto board) =>
        board.BoardExportStatus == BoardExportStatus.Completed
        && board.ReExportStatus == BoardExportStatus.None;

    private async Task DownloadArchiveAsync()
    {
        if (_isDownloadingArchive)
            return;

        _isDownloadingArchive = true;

        try
        {
            await BoardArchiveDownloadService.DownloadAsync(BoardId);
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
        finally
        {
            _isDownloadingArchive = false;
        }
    }

    private async Task ReExportBoardAsync()
    {
        if (BoardDetailsStore.Board is not { } board)
            return;

        var submitState = new ResourceFormDialogState();

        var dialog = await DialogService.ShowResourceFormAsync(
            "Create new copy",
            "Create copy",
            ReExportBoardForm.FormId,
            ReExportBoardForm.Render(board.ExportOptions, submitState),
            submitButtonClass: "btn-dialog-warning btn-dialog-action",
            submitState: submitState);

        var result = await dialog.Result;

        if (result is not { Canceled: false, Data: BoardExportOptions exportOptions })
            return;

        try
        {
            await BoardApiService.ReExportArchivedBoardAsync(BoardId, exportOptions);
            BoardDetailsStore.SetBoardReExportPending(exportOptions);
            BoardStore.ApplyBoardReExportPending(BoardId);
            Snackbar.Add("New copy creation started.", Severity.Success);
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
    }

    protected override void OnInitialized()
    {
        BoardDetailsStore.StateChanged += OnBoardDetailsStoreStateChanged;
        BoardDetailsStore.RemoteBoardNameApplied += OnRemoteBoardNameApplied;
        EntitlementsStore.StateChanged += OnEntitlementsChanged;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusTitleInput)
        {
            _focusTitleInput = false;
            await _titleInputRef.FocusAsync();
        }
    }

    public void Dispose()
    {
        BoardDetailsStore.StateChanged -= OnBoardDetailsStoreStateChanged;
        BoardDetailsStore.RemoteBoardNameApplied -= OnRemoteBoardNameApplied;
        EntitlementsStore.StateChanged -= OnEntitlementsChanged;
    }

    private string GetTitleClass(bool editable)
    {
        var classes = editable
            ? "text-section-title board-page__title board-page__title--editable"
            : "text-section-title board-page__title";

        if (_isNameHighlighted)
            classes += " board-page__title--remote-updated";

        return classes;
    }

    private void OnRemoteBoardNameApplied()
    {
        if (_isEditingName)
            return;

        _ = HighlightRemoteNameAsync();
    }

    private async Task HighlightRemoteNameAsync()
    {
        var token = ++_nameHighlightToken;
        _isNameHighlighted = true;
        await InvokeAsync(StateHasChanged);

        await Task.Delay(1000);

        if (token != _nameHighlightToken)
            return;

        _isNameHighlighted = false;
        await InvokeAsync(StateHasChanged);
    }

    private void OnBoardDetailsStoreStateChanged() =>
        InvokeAsync(StateHasChanged);

    private void OnEntitlementsChanged() =>
        InvokeAsync(StateHasChanged);

    private async Task ToggleCallsSidebarAsync()
    {
        if (CallSessionStore.IsSidebarOpen)
        {
            CallSessionStore.CloseSidebar();
            return;
        }

        await CallSessionStore.OpenSidebarAsync(BoardId);
    }

    private async Task OpenMembersOverlayAsync()
    {
        if (BoardDetailsStore.Board is not { } board)
            return;

        if (!BoardRolePermissions.CanViewBoard(board.UserRole))
            return;

        try
        {
            await BoardMembersStore.OpenAsync(BoardId, board.UserRole);
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
    }

    private async Task LeaveBoardAsync()
    {
        var message =
            $"Leave board \"{BoardDetailsStore.Board?.Name}\"?{Environment.NewLine}You will lose access to this board.";

        var dialog = await DialogService.ShowConfirmResourceAsync(
            "Leave board",
            message,
            confirmLabel: "Leave",
            submitButtonClass: "btn-glass btn-dialog-action");

        var result = await dialog.Result;

        if (result is not { Canceled: false, Data: true })
            return;

        try
        {
            await BoardApiService.LeaveBoardAsync(BoardId);
            Snackbar.Add("You left the board.", Severity.Success);
            Navigation.NavigateTo("/boards");
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
    }

    private void StartNameEdit()
    {
        if (!CanRenameBoard || BoardDetailsStore.Board is null || _isEditingName)
            return;

        _editName = BoardDetailsStore.Board.Name;
        _isEditingName = true;
        _focusTitleInput = true;
    }

    private void CancelNameEdit()
    {
        _isEditingName = false;
        _editName = BoardDetailsStore.Board?.Name ?? string.Empty;
    }

    private async Task OnTitleKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SaveBoardNameAsync();
        else if (e.Key == "Escape")
            CancelNameEdit();
    }

    private async Task OnTitleBlurAsync()
    {
        if (!_isEditingName)
            return;

        await SaveBoardNameAsync();
    }

    private async Task SaveBoardNameAsync()
    {
        if (!_isEditingName || BoardDetailsStore.Board is null || _isSavingName)
            return;

        var trimmedName = _editName.Trim();

        if (string.IsNullOrEmpty(trimmedName))
        {
            Snackbar.Add("Board name is required.", Severity.Error);
            return;
        }

        if (trimmedName.Length > 100)
        {
            Snackbar.Add("Board name must not exceed 100 characters.", Severity.Error);
            return;
        }

        if (string.Equals(trimmedName, BoardDetailsStore.Board.Name, StringComparison.Ordinal))
        {
            CancelNameEdit();
            return;
        }

        _isSavingName = true;

        try
        {
            await BoardApiService.UpdateBoardAsync(BoardId, trimmedName);
            BoardDetailsStore.UpdateBoardName(trimmedName);
            _isEditingName = false;
            Snackbar.Add("Board updated.", Severity.Success);
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
        finally
        {
            _isSavingName = false;
        }
    }

    private async Task DeleteBoardAsync()
    {
        var message =
            $"Delete board \"{BoardDetailsStore.Board?.Name}\"?{Environment.NewLine}This action cannot be undone.";

        var dialog = await DialogService.ShowConfirmResourceAsync(
            "Delete board",
            message,
            confirmLabel: "Delete");

        var result = await dialog.Result;

        if (result is not { Canceled: false, Data: true })
            return;

        try
        {
            await BoardApiService.DeleteBoardAsync(BoardId);
            Snackbar.Add("Board deleted.", Severity.Success);
            Navigation.NavigateTo("/boards");
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
    }

    private async Task ArchiveBoardAsync()
    {
        if (BoardDetailsStore.Board is not { Name: var boardName })
            return;

        var dialog = await DialogService.ShowResourceFormAsync(
            "Archive board",
            "Archive",
            ArchiveBoardForm.FormId,
            ArchiveBoardForm.Render(boardName),
            submitButtonClass: "btn-dialog-warning btn-dialog-action");

        var result = await dialog.Result;

        if (result is not { Canceled: false, Data: BoardExportOptions exportOptions })
            return;

        try
        {
            var archived = await BoardApiService.ArchiveAndExportBoardAsync(BoardId, exportOptions);
            BoardDetailsStore.SetBoardArchived(
                archived.ArchivedAtUtc,
                archived.BoardExportStatus,
                exportOptions);
            BoardStore.ApplyBoardArchived(BoardId, archived.ArchivedAtUtc, archived.BoardExportStatus);
            Snackbar.Add("Board archived.", Severity.Success);
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
    }
}
