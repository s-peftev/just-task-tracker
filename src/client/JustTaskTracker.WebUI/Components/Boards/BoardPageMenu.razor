@using JustTaskTracker.WebUI.Domain.Billing.Constants
@using JustTaskTracker.WebUI.Domain.Boards.Authorization
@using JustTaskTracker.WebUI.Domain.Boards.Enums
@using JustTaskTracker.WebUI.Services.Abstractions.Billing
@using JustTaskTracker.WebUI.Services.Abstractions.Boards
@implements IDisposable
@inject IBoardDetailsStore BoardDetailsStore
@inject IEntitlementsStore EntitlementsStore

<div class="board-menu">
    <button type="button"
            class="btn-icon btn-icon--round btn-icon--md"
            aria-label="Board menu"
            aria-expanded="@_isOpen"
            aria-haspopup="true"
            @onclick="Toggle">
        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <circle cx="5" cy="12" r="1.5" fill="currentColor" />
            <circle cx="12" cy="12" r="1.5" fill="currentColor" />
            <circle cx="19" cy="12" r="1.5" fill="currentColor" />
        </svg>
    </button>

    @if (_isOpen)
    {
        <button type="button"
                class="board-menu__backdrop"
                aria-label="Close menu"
                @onclick="Close"></button>

        <div class="board-menu__panel" role="menu">
            <div class="board-menu__header">
                <span class="board-menu__title">Menu</span>
            </div>

            <label class="board-menu__filter"
                   role="menuitemcheckbox"
                   aria-checked="@BoardDetailsStore.ShowOnlyMyTasks">
                <input type="checkbox"
                       checked="@BoardDetailsStore.ShowOnlyMyTasks"
                       @onchange="OnMyTasksFilterChanged" />
                <span>Show only tasks assigned to me</span>
            </label>

            @if (CanViewBoard || CanLeaveBoard || CanArchiveBoard || CanDeleteBoard)
            {
                <div class="board-menu__divider" role="separator"></div>
            }

            @if (CanViewBoard)
            {
                <button type="button"
                        class="board-menu__item"
                        role="menuitem"
                        @onclick="HandleMembersClickAsync">
                    <svg class="board-menu__item-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5C15 14.17 10.33 13 8 13zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
                              fill="currentColor" />
                    </svg>
                    <span>Members</span>
                </button>
            }

            @if (CanManageMembers && CanLeaveBoard)
            {
                <div class="board-menu__divider" role="separator"></div>
            }

            @if (CanLeaveBoard)
            {
                <button type="button"
                        class="board-menu__item"
                        role="menuitem"
                        @onclick="HandleLeaveBoardClickAsync">
                    <svg class="board-menu__item-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M17 7l-1.41 1.41L18.17 11H8v2h10.17l-2.58 2.58L17 17l5-5-5-5zM4 5h8V3H4c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h8v-2H4V5z"
                              fill="currentColor" />
                    </svg>
                    <span>Leave board</span>
                </button>
            }

            @if (CanArchiveBoard)
            {
                @if (CanManageMembers || CanLeaveBoard)
                {
                    <div class="board-menu__divider" role="separator"></div>
                }

                <button type="button"
                        class="board-menu__item board-menu__item--warning"
                        role="menuitem"
                        @onclick="HandleArchiveBoardClickAsync">
                    <svg class="board-menu__item-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M20.54 5.23l-1.39-1.68C18.88 3.21 18.47 3 18 3H6c-.47 0-.88.21-1.16.55L3.46 5.23C3.17 5.57 3 6.02 3 6.5V19c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6.5c0-.48-.17-.93-.46-1.27zM12 17.5 6.5 12H10v-2h4v2h3.5L12 17.5zM5.12 5l.81-1h12l.94 1H5.12z"
                              fill="currentColor" />
                    </svg>
                    <span>Archive board</span>
                </button>
            }

            @if (CanDeleteBoard)
            {
                @if (CanManageMembers || CanLeaveBoard)
                {
                    <div class="board-menu__divider" role="separator"></div>
                }

                <button type="button"
                        class="board-menu__item board-menu__item--danger"
                        role="menuitem"
                        @onclick="HandleDeleteBoardClickAsync">
                    <svg class="board-menu__item-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M6 19c0 1.1.9 2 2 2h8c1.1 0 2-.9 2-2V7H6v12zM19 4h-3.5l-1-1h-5l-1 1H5v2h14V4z"
                              fill="currentColor" />
                    </svg>
                    <span>Delete board</span>
                </button>
            }
        </div>
    }
</div>

@code {
    [Parameter]
    public BoardMemberRole UserRole { get; set; }

    [Parameter]
    public EventCallback OnMembersClick { get; set; }

    [Parameter]
    public EventCallback OnLeaveBoardClick { get; set; }

    [Parameter]
    public EventCallback OnArchiveBoardClick { get; set; }

    [Parameter]
    public EventCallback OnDeleteBoardClick { get; set; }

    private bool CanViewBoard => BoardRolePermissions.CanViewBoard(UserRole);
    private bool CanManageMembers => BoardRolePermissions.CanManageMembers(UserRole);
    private bool CanLeaveBoard => BoardRolePermissions.CanLeaveBoard(UserRole);
    private bool CanArchiveBoard =>
        BoardRolePermissions.CanArchiveBoard(UserRole)
        && BoardDetailsStore.Board is { IsArchived: false }
        && EntitlementsStore.Can(Features.BoardExport);
    private bool CanDeleteBoard => BoardRolePermissions.CanDeleteBoard(UserRole);

    private bool _isOpen;

    protected override void OnInitialized()
    {
        BoardDetailsStore.StateChanged += OnBoardDetailsStoreStateChanged;
        EntitlementsStore.StateChanged += OnEntitlementsStoreStateChanged;
    }

    public void Dispose()
    {
        BoardDetailsStore.StateChanged -= OnBoardDetailsStoreStateChanged;
        EntitlementsStore.StateChanged -= OnEntitlementsStoreStateChanged;
    }

    private void OnBoardDetailsStoreStateChanged() =>
        InvokeAsync(StateHasChanged);

    private void OnEntitlementsStoreStateChanged() =>
        InvokeAsync(StateHasChanged);

    private void Toggle() =>
        _isOpen = !_isOpen;

    private void Close() =>
        _isOpen = false;

    private void OnMyTasksFilterChanged(ChangeEventArgs e)
    {
        var showOnlyMyTasks = e.Value is true;
        BoardDetailsStore.SetShowOnlyMyTasks(showOnlyMyTasks);
    }

    private async Task HandleMembersClickAsync()
    {
        Close();
        await OnMembersClick.InvokeAsync();
    }

    private async Task HandleLeaveBoardClickAsync()
    {
        Close();
        await OnLeaveBoardClick.InvokeAsync();
    }

    private async Task HandleArchiveBoardClickAsync()
    {
        Close();
        await OnArchiveBoardClick.InvokeAsync();
    }

    private async Task HandleDeleteBoardClickAsync()
    {
        Close();
        await OnDeleteBoardClick.InvokeAsync();
    }
}
