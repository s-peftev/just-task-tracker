@using JustTaskTracker.WebUI.Components.Shared
@using JustTaskTracker.WebUI.Domain.Billing
@using JustTaskTracker.WebUI.Domain.Boards
@using JustTaskTracker.WebUI.Domain.Boards.Authorization
@using JustTaskTracker.WebUI.Domain.Boards.Requests
@using JustTaskTracker.WebUI.Services.Abstractions.Auth
@using JustTaskTracker.WebUI.Services.Abstractions.Boards
@using JustTaskTracker.WebUI.Services.Exceptions
@implements IDisposable
@inject IBoardDetailsStore BoardDetailsStore
@inject IBoardMembersStore BoardMembersStore
@inject IBoardApiService BoardApiService
@inject IProfileStore ProfileStore
@inject ISnackbar Snackbar

@if (BoardDetailsStore.Board is { } board)
{
    <div class="board-page-stats" role="group" aria-label="Board usage">
        <HoverTooltip>
            <Trigger>
                <div class="board-page-stats__item @(IsLimitReached(ColumnCount(board), board.Limits.MaxColumnsPerBoard) ? "board-page-stats__item--limit-reached" : null)"
                     aria-label="@GetColumnsAriaLabel(board)">
                    <svg class="board-page-stats__icon" viewBox="0 0 52 52" aria-hidden="true" focusable="false">
                        <path d="M32,17.5c0-0.8-0.7-1.5-1.5-1.5h-9c-0.8,0-1.5,0.7-1.5,1.5v27c0,0.8,0.7,1.5,1.5,1.5h9c0.8,0,1.5-0.7,1.5-1.5V17.5z" fill="currentColor" />
                        <path d="M14,17.5c0-0.8-0.7-1.5-1.5-1.5h-9C2.7,16,2,16.7,2,17.5v31C2,49.3,2.7,50,3.5,50h9c0.8,0,1.5-0.7,1.5-1.5V17.5z" fill="currentColor" />
                        <path d="M50,17.5c0-0.8-0.7-1.5-1.5-1.5h-9c-0.8,0-1.5,0.7-1.5,1.5v23c0,0.8,0.7,1.5,1.5,1.5h9c0.8,0,1.5-0.7,1.5-1.5V17.5z" fill="currentColor" />
                        <path d="M50,3.5C50,2.7,49.3,2,48.5,2h-45C2.7,2,2,2.7,2,3.5v5C2,9.3,2.7,10,3.5,10h45c0.8,0,1.5-0.7,1.5-1.5V3.5z" fill="currentColor" />
                    </svg>
                    <span class="board-page-stats__value">@FormatUsage(ColumnCount(board), board.Limits.MaxColumnsPerBoard)</span>
                </div>
            </Trigger>
            <ChildContent>
                <p class="hover-tooltip__panel-text">@GetColumnsTooltip(board)</p>
            </ChildContent>
        </HoverTooltip>

        <HoverTooltip>
            <Trigger>
                <div class="board-page-stats__item @(IsLimitReached(TaskCount(board), board.Limits.MaxTasksPerBoard) ? "board-page-stats__item--limit-reached" : null)"
                     aria-label="@GetTasksAriaLabel(board)">
                    <svg class="board-page-stats__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M9 5h12M9 12h12M9 19h12"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round" />
                        <path d="M4 5h.01M4 12h.01M4 19h.01"
                              fill="none"
                              stroke="currentColor"
                              stroke-width="3"
                              stroke-linecap="round" />
                    </svg>
                    <span class="board-page-stats__value">@FormatUsage(TaskCount(board), board.Limits.MaxTasksPerBoard)</span>
                </div>
            </Trigger>
            <ChildContent>
                <p class="hover-tooltip__panel-text">@GetTasksTooltip(board)</p>
            </ChildContent>
        </HoverTooltip>

        <HoverTooltip>
            <Trigger>
                <button type="button"
                        class="board-page-stats__item board-page-stats__item--action @(BoardDetailsStore.ShowOnlyMyTasks ? "board-page-stats__item--active" : null)"
                        aria-pressed="@BoardDetailsStore.ShowOnlyMyTasks"
                        aria-label="@GetAssignedAriaLabel(board)"
                        @onclick="ToggleMyTasksFilter">
                    <svg class="board-page-stats__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2" fill="none" />
                        <path d="M3 21v-2a4 4 0 0 1 4-4h4"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              fill="none" />
                        <path d="M16 11l2 2 5-5"
                              stroke="currentColor"
                              stroke-width="2"
                              stroke-linecap="round"
                              stroke-linejoin="round"
                              fill="none" />
                    </svg>
                    <span class="board-page-stats__value">@AssignedToMeCount(board)</span>
                </button>
            </Trigger>
            <ChildContent>
                <p class="hover-tooltip__panel-text">@GetAssignedTooltip(board)</p>
            </ChildContent>
        </HoverTooltip>

        @if (CanViewMembers(board))
        {
            <HoverTooltip>
                <Trigger>
                    <button type="button"
                            class="board-page-stats__item board-page-stats__item--action @(IsLimitReached(MemberCount, board.Limits.MaxMembersPerBoard) ? "board-page-stats__item--limit-reached" : null)"
                            aria-label="@GetMembersAriaLabel(board)"
                            @onclick="OpenMembersAsync">
                        <svg class="board-page-stats__icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5s-3 1.34-3 3 1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5C15 14.17 10.33 13 8 13zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"
                                  fill="currentColor" />
                        </svg>
                        <span class="board-page-stats__value">@FormatUsage(MemberCount, board.Limits.MaxMembersPerBoard)</span>
                    </button>
                </Trigger>
                <ChildContent>
                    <p class="hover-tooltip__panel-text">@GetMembersTooltip(board)</p>
                </ChildContent>
            </HoverTooltip>
        }
    </div>
}

@code {
    [Parameter, EditorRequired]
    public Guid BoardId { get; set; }

    [Parameter]
    public EventCallback OnMembersClick { get; set; }

    private int? _memberCount;
    private Guid? _memberCountBoardId;
    private CancellationTokenSource? _memberCountCts;

    protected override void OnInitialized()
    {
        BoardDetailsStore.StateChanged += OnStoreChanged;
        BoardMembersStore.StateChanged += OnMembersStoreChanged;
        ProfileStore.StateChanged += OnStoreChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_memberCountBoardId != BoardId)
        {
            _memberCount = null;
            _memberCountBoardId = null;
        }

        if (BoardDetailsStore.Board is null)
            return;

        await EnsureMemberCountAsync();
    }

    public void Dispose()
    {
        BoardDetailsStore.StateChanged -= OnStoreChanged;
        BoardMembersStore.StateChanged -= OnMembersStoreChanged;
        ProfileStore.StateChanged -= OnStoreChanged;
        _memberCountCts?.Cancel();
        _memberCountCts?.Dispose();
    }

    private int MemberCount => _memberCount ?? 0;

    private static int ColumnCount(BoardDetailsDto board) =>
        board.Columns.Count;

    private static int TaskCount(BoardDetailsDto board) =>
        board.Columns.Sum(column => column.BoardTasks.Count);

    private int AssignedToMeCount(BoardDetailsDto board)
    {
        if (ProfileStore.Profile is not { } profile)
            return 0;

        return board.Columns
            .SelectMany(column => column.BoardTasks)
            .Count(task => task.IsAssignedToCurrentUser(profile.Id));
    }

    private static string FormatUsage(int count, int? max) =>
        max is null ? count.ToString() : $"{count} / {max}";

    private static bool IsLimitReached(int count, int? max) =>
        max is int limit && count >= limit;

    private static string GetColumnsTooltip(BoardDetailsDto board)
    {
        var count = ColumnCount(board);
        return board.Limits.MaxColumnsPerBoard is int max
            ? $"{count} columns total. This board has a limit of {max} columns."
            : $"{count} columns total.";
    }

    private static string GetTasksTooltip(BoardDetailsDto board)
    {
        var count = TaskCount(board);
        return board.Limits.MaxTasksPerBoard is int max
            ? $"{count} tasks total. This board has a limit of {max} tasks."
            : $"{count} tasks total.";
    }

    private string GetAssignedTooltip(BoardDetailsDto board)
    {
        var count = AssignedToMeCount(board);
        return $"{count} tasks assigned to you. Click to filter.";
    }

    private string GetMembersTooltip(BoardDetailsDto board)
    {
        var count = MemberCount;
        var baseText = board.Limits.MaxMembersPerBoard is int max
            ? $"{count} members total. This board has a limit of {max} members."
            : $"{count} members total.";

        return $"{baseText} Click to manage members.";
    }

    private static string GetColumnsAriaLabel(BoardDetailsDto board) =>
        GetColumnsTooltip(board);

    private static string GetTasksAriaLabel(BoardDetailsDto board) =>
        GetTasksTooltip(board);

    private string GetAssignedAriaLabel(BoardDetailsDto board) =>
        GetAssignedTooltip(board);

    private string GetMembersAriaLabel(BoardDetailsDto board) =>
        GetMembersTooltip(board);

    private static bool CanViewMembers(BoardDetailsDto board) =>
        BoardRolePermissions.CanViewBoard(board.UserRole);

    private void ToggleMyTasksFilter() =>
        BoardDetailsStore.SetShowOnlyMyTasks(!BoardDetailsStore.ShowOnlyMyTasks);

    private async Task OpenMembersAsync() =>
        await OnMembersClick.InvokeAsync();

    private void OnStoreChanged() =>
        InvokeAsync(async () =>
        {
            await EnsureMemberCountAsync();
            StateHasChanged();
        });

    private void OnMembersStoreChanged() =>
        InvokeAsync(() =>
        {
            if (BoardMembersStore is { IsOpen: true, BoardId: { } membersBoardId }
                && membersBoardId == BoardId
                && string.IsNullOrWhiteSpace(BoardMembersStore.SearchText))
            {
                _memberCount = BoardMembersStore.Pagination.TotalCount;
                _memberCountBoardId = BoardId;
            }

            StateHasChanged();
        });

    private async Task EnsureMemberCountAsync()
    {
        if (BoardDetailsStore.Board is null || !CanViewMembers(BoardDetailsStore.Board))
            return;

        if (_memberCountBoardId == BoardId && _memberCount is not null)
            return;

        _memberCountCts?.Cancel();
        _memberCountCts?.Dispose();
        _memberCountCts = new CancellationTokenSource();
        var ct = _memberCountCts.Token;

        try
        {
            var page = await BoardApiService.GetBoardMembersAsync(
                BoardId,
                new GetBoardMembersRequest
                {
                    PageNumber = 1,
                    PageSize = 1,
                },
                ct);

            if (ct.IsCancellationRequested)
                return;

            _memberCount = page.Metadata.TotalCount;
            _memberCountBoardId = BoardId;
        }
        catch (OperationCanceledException)
        {
        }
        catch (ApiServiceException)
        {
            // Stats are best-effort; board page remains usable without member count.
        }
    }
}
