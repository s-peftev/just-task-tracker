@using JustTaskTracker.WebUI.Domain.Boards
@using JustTaskTracker.WebUI.Domain.Boards.Enums

@foreach (var role in BoardMemberRoleFormatting.AssignableRoles)
{
    <MudSelectItem T="BoardMemberRole"
                   Value="@role"
                   Disabled="@(IsGlobalAdmin && !BoardMemberRoleFormatting.IsAssignableForGlobalAdmin(role))">
        @BoardMemberRoleFormatting.Format(role)
    </MudSelectItem>
}

@code {
    [Parameter]
    public bool IsGlobalAdmin { get; set; }
}
