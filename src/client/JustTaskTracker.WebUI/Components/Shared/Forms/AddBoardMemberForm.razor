@using JustTaskTracker.WebUI.Domain.Auth
@using JustTaskTracker.WebUI.Domain.Boards
@using JustTaskTracker.WebUI.Domain.Boards.Enums

<form id="@FormId" class="add-board-member-form" @onsubmit="SubmitAsync" @onsubmit:preventDefault="true">
    <p class="confirm-dialog__message add-board-member-form__message">
        Add @DisplayName to this board?
    </p>

    <div class="add-board-member-form__role-field">
        <MudSelect T="BoardMemberRole"
                   @bind-Value="_selectedRole"
                   Label="Role"
                   Variant="Variant.Outlined"
                   AnchorOrigin="Origin.BottomCenter"
                   TransformOrigin="Origin.TopCenter">
            <BoardMemberRoleSelectItems IsGlobalAdmin="User.IsGlobalAdmin" />
        </MudSelect>

        @if (User.IsGlobalAdmin)
        {
            <p class="add-board-member-form__role-hint">@BoardMemberRoleFormatting.GlobalAdminBoardRoleHint</p>
        }
    </div>
</form>

@code {
    public const string FormId = "add-board-member-form";

    [Parameter, EditorRequired]
    public UserForBoardLookupDto User { get; set; } = default!;

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    private BoardMemberRole _selectedRole = BoardMemberRole.User;

    private string DisplayName => UserDisplayFormatting.GetShortName(User);

    protected override void OnInitialized()
    {
        _selectedRole = User.IsGlobalAdmin
            ? BoardMemberRole.Admin
            : BoardMemberRole.User;
    }

    public static RenderFragment Render(UserForBoardLookupDto user) => builder =>
    {
        builder.OpenComponent<AddBoardMemberForm>(0);
        builder.AddAttribute(1, nameof(User), user);
        builder.CloseComponent();
    };

    private void SubmitAsync() =>
        MudDialog.Close(DialogResult.Ok(_selectedRole));
}
