<div class="message-card">
    <MudText Typo="Typo.h5" Style="margin-bottom: 0.25rem;">
        @Title
    </MudText>
    <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.55);">
        @Message
    </MudText>
</div>

@code {
    [Parameter, EditorRequired]
    public string Title { get; set; } = default!;

    [Parameter, EditorRequired]
    public string Message { get; set; } = default!;
}
