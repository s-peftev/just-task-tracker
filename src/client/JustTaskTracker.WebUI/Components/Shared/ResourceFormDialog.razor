<MudDialog Class="resource-form-dialog" ActionsClass="resource-form-dialog__actions">
    <DialogContent>
        @ChildContent
    </DialogContent>
    <DialogActions>
        <MudButton Class="btn-dialog-cancel btn-dialog-action"
                   ButtonType="ButtonType.Button"
                   OnClick="Cancel">
            Cancel
        </MudButton>
        <MudButton Class="btn-glass btn-dialog-action"
                   ButtonType="ButtonType.Submit"
                   form="@FormId"
                   Disabled="@DisableSubmit">
            @SubmitLabel
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    public static DialogOptions DefaultOptions { get; } = new()
    {
        CloseOnEscapeKey = true,
        MaxWidth = MaxWidth.ExtraSmall,
        FullWidth = true
    };

    [CascadingParameter]
    private IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public string FormId { get; set; } = "resource-form";

    [Parameter]
    public string SubmitLabel { get; set; } = "Save";

    [Parameter]
    public bool DisableSubmit { get; set; }

    private void Cancel() => MudDialog.Cancel();
}
