@inherits LayoutComponentBase
@implements IDisposable
@inject NavigationManager Navigation
@inject IProfileStore ProfileStore
@inject AuthenticationStateProvider AuthStateProvider

<MudThemeProvider />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<MudLayout>
    <MudAppBar Elevation="1">
        <MudText Typo="Typo.h6">Just Task Tracker</MudText>
        <MudSpacer />
        <AuthorizeView>
            <Authorized>
                @{
                    var displayName = ProfileStore.Profile?.DisplayName
                        ?? ProfileStore.Profile?.Email
                        ?? context.User.Identity?.Name;
                }
                <MudText Class="mr-4">@displayName</MudText>
                <MudButton Color="Color.Inherit" OnClick="Logout">Logout</MudButton>
            </Authorized>
        </AuthorizeView>
    </MudAppBar>
    <MudMainContent>
        <MudContainer MaxWidth="MaxWidth.Large" Class="mt-6">
            @Body
        </MudContainer>
    </MudMainContent>
</MudLayout>

@code {
    protected override void OnInitialized() =>
        ProfileStore.StateChanged += OnStoreStateChanged;

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated == true)
            await ProfileStore.EnsureLoadedAsync();
    }

    public void Dispose() => ProfileStore.StateChanged -= OnStoreStateChanged;

    private void OnStoreStateChanged() => InvokeAsync(StateHasChanged);

    private void Logout()
    {
        ProfileStore.Reset();
        Navigation.NavigateToLogout("authentication/logout");
    }
}
