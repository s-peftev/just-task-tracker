@inherits LayoutComponentBase
@implements IDisposable
@using Microsoft.AspNetCore.Components.Authorization
@using JustTaskTracker.WebUI.Infrastructure
@using JustTaskTracker.WebUI.Services.Abstractions.Billing
@inject IProfileStore ProfileStore
@inject IEntitlementsStore EntitlementsStore
@inject IBoardStore BoardStore
@inject AuthenticationStateProvider AuthState
@inject NavigationManager Navigation
@inject IJSRuntime Js

<MudThemeProvider Theme="@_theme" IsDarkMode="true" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<div class="layout-wrapper">
    <AppNavBar />
    <main class="layout-main">
        @if (ProfileStore.Profile is { } profile)
        {
            <div class="sidebar-shell @(_isSidebarCollapsed ? "sidebar-shell--collapsed" : null)">
                <div class="sidebar-shell__sidebar">
                    <AppSidebar @key="profile.Id" />
                </div>

                <button type="button"
                        class="sidebar-shell__toggle"
                        aria-label="@(_isSidebarCollapsed ? "Expand sidebar" : "Collapse sidebar")"
                        title="@(_isSidebarCollapsed ? "Expand sidebar" : "Collapse sidebar")"
                        @onclick="ToggleSidebar">
                    <span class="sidebar-shell__toggle-icon @(_isSidebarCollapsed ? "sidebar-shell__toggle-icon--right" : "sidebar-shell__toggle-icon--left")"
                          aria-hidden="true"></span>
                </button>

                <section class="sidebar-shell__content">
                    @Body
                </section>
            </div>
        }
        else if (_isAuthenticated)
        {
            <div class="sidebar-shell sidebar-shell--center">
                @if (ProfileStore.IsLoading)
                {
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                }
                else if (ProfileStore.ErrorMessage is { } error)
                {
                    <MudAlert Severity="Severity.Error">@error</MudAlert>
                }
                else
                {
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                }
            </div>
        }
        else
        {
            @Body
        }
    </main>
</div>

@code {
    private static readonly MudTheme _theme = new()
    {
        PaletteDark = new PaletteDark
        {
            Primary = "#95CD41",
            PrimaryContrastText = "#1a1a1a",
        }
    };

    private bool _isAuthenticated;
    private bool _isSidebarCollapsed;

    protected override void OnInitialized()
    {
        ProfileStore.StateChanged += OnStoreStateChanged;
        EntitlementsStore.StateChanged += OnStoreStateChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        _isAuthenticated = authState.User.Identity?.IsAuthenticated == true;

        if (!_isAuthenticated)
            return;

        var switchResult = await MicrosoftAuthNavigation.TryCompleteAccountSwitchAsync(Js, AuthState);
        if (switchResult == AccountSwitchResult.SameAccountRequiresFullLogout)
        {
            await EnsureProfileAndEntitlementsAsync(AccountSwitchResult.Switched);
            return;
        }

        await EnsureProfileAndEntitlementsAsync(switchResult);

        if (ProfileStore.RequiresLogin)
            Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        ProfileStore.StateChanged -= OnStoreStateChanged;
        EntitlementsStore.StateChanged -= OnStoreStateChanged;
    }

    private void OnStoreStateChanged() => InvokeAsync(StateHasChanged);

    private void ToggleSidebar() => _isSidebarCollapsed = !_isSidebarCollapsed;

    /// <summary>
    /// Loads profile first, then entitlements. Sequential on purpose: first login
    /// provisions the app user via ProfileStore (GET me → POST login); entitlements
    /// require that user to exist, so parallel would race on a cold account.
    /// </summary>
    private async Task EnsureProfileAndEntitlementsAsync(AccountSwitchResult switchResult)
    {
        var authState = await AuthState.GetAuthenticationStateAsync();
        if (authState.User.Identity?.IsAuthenticated != true)
            return;

        var needsRefresh = switchResult == AccountSwitchResult.Switched
            || !ProfileStore.IsLoaded
            || ProfileStore.Profile is not { } cached
            || !MicrosoftAuthNavigation.ProfileMatchesAuth(cached, authState.User);

        if (needsRefresh)
            await ProfileStore.RefreshAsync();
        else
            await ProfileStore.EnsureLoadedAsync();

        if (ProfileStore.RequiresLogin || !ProfileStore.IsLoaded || ProfileStore.Profile is null)
            return;

        if (needsRefresh)
            await EntitlementsStore.RefreshAsync();
        else
            await EntitlementsStore.EnsureLoadedAsync();
    }
}
