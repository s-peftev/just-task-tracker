@using JustTaskTracker.WebUI.Domain.Billing
@using JustTaskTracker.WebUI.Domain.Billing.Constants
@using JustTaskTracker.WebUI.Infrastructure
@using JustTaskTracker.WebUI.Services.Abstractions.Billing
@using JustTaskTracker.WebUI.Services.Abstractions.Hubs
@implements IDisposable
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthState
@inject IProfileStore ProfileStore
@inject IEntitlementsStore EntitlementsStore
@inject IBoardStore BoardStore
@inject IBoardExportStatusHubService HubService
@inject IBoardActionsHubService BoardActionsHubService
@inject IJSRuntime Js

@if (ProfileStore.Profile is { } profile)
{
    <aside class="sidebar">
        <div class="sidebar__profile">
            <SidebarProfileAvatar DisplayName="@profile.DisplayName"
                                  Email="@profile.Email"
                                  ProfilePhotoUrl="@profile.ProfilePhotoUrl" />

            <div class="sidebar__info">
                <p class="sidebar__name text-sidebar-user">@UserDisplayFormatting.GetShortName(profile)</p>
                <p class="sidebar__email text-sidebar-user">@profile.Email</p>

                @if (profile.Roles.Count > 0)
                {
                    <div class="sidebar__roles">
                        @foreach (var role in profile.Roles)
                        {
                            <span class="sidebar__role text-sidebar-user">@role</span>
                        }
                    </div>
                }
            </div>
        </div>

        <div class="sidebar__divider" role="separator" />

        <nav class="sidebar__nav" aria-label="Main sections">
            <NavLink href="/boards"
                     class="sidebar__tab text-sidebar-tab"
                     ActiveClass="sidebar__tab--active"
                     Match="NavLinkMatch.All">
                Boards
            </NavLink>
            @if (CanViewSubscriptions(profile))
            {
                <NavLink href="/subscriptions"
                         class="@SubscriptionsTabCssClass"
                         ActiveClass="sidebar__tab--active"
                         Match="NavLinkMatch.All">
                    Subscriptions
                    @if (CurrentPlanBadge is { } planBadge)
                    {
                        <span class="sidebar__plan-meta">
                            @if (ShowPastDueWarning)
                            {
                                <span class="sidebar__past-due"
                                      tabindex="0"
                                      aria-label="@SubscriptionStatusCopy.PastDueNotice">
                                    <svg class="sidebar__past-due-icon"
                                         viewBox="0 0 24 24"
                                         aria-hidden="true"
                                         focusable="false">
                                        <path fill="currentColor"
                                              d="M1 21h22L12 2 1 21zm12-3h-2v-2h2v2zm0-4h-2v-4h2v4z" />
                                    </svg>
                                    <span class="sidebar__past-due-tooltip" aria-hidden="true">
                                        @SubscriptionStatusCopy.PastDueNotice
                                    </span>
                                </span>
                            }
                            <span class="sidebar__plan-badge @planBadge.CssClass"
                                  aria-label="@($"Current plan: {planBadge.Label}")">
                                @planBadge.Label
                            </span>
                        </span>
                    }
                </NavLink>
            }
        </nav>

        <div class="sidebar__footer">
            <button type="button"
                    class="sidebar__footer-action text-sidebar-tab"
                    @onclick="SwitchMicrosoftAccount">
                Switch Microsoft account
            </button>
            <button type="button"
                    class="sidebar__footer-action text-sidebar-tab"
                    @onclick="Logout">
                Log out
            </button>
        </div>
    </aside>
}

@code {
    protected override void OnInitialized()
    {
        ProfileStore.StateChanged += OnStoreStateChanged;
        EntitlementsStore.StateChanged += OnStoreStateChanged;
    }

    public void Dispose()
    {
        ProfileStore.StateChanged -= OnStoreStateChanged;
        EntitlementsStore.StateChanged -= OnStoreStateChanged;
    }

    private void OnStoreStateChanged() =>
        InvokeAsync(StateHasChanged);

    private static bool CanViewSubscriptions(UserWithRolesDto profile) =>
        profile.Roles.Any(r => r.Equals("User", StringComparison.OrdinalIgnoreCase));

    private bool ShowPastDueWarning =>
        EntitlementsStore.Entitlements is { Status: var status }
        && status.Equals(SubscriptionStatuses.PastDue, StringComparison.OrdinalIgnoreCase);

    private string SubscriptionsTabCssClass =>
        ShowPastDueWarning
            ? "sidebar__tab sidebar__tab--subscriptions sidebar__tab--subscriptions-past-due text-sidebar-tab"
            : "sidebar__tab sidebar__tab--subscriptions text-sidebar-tab";

    private PlanBadge? CurrentPlanBadge
    {
        get
        {
            if (EntitlementsStore.Entitlements is not { PlanDisplayName: { Length: > 0 } displayName } entitlements)
                return null;

            var cssClass = entitlements.PlanId.ToLowerInvariant() switch
            {
                "free" => "sidebar__plan-badge--free",
                "pro" => "sidebar__plan-badge--pro",
                _ => null
            };

            return new PlanBadge(displayName.ToUpperInvariant(), cssClass);
        }
    }

    private async Task SwitchMicrosoftAccount()
    {
        ProfileStore.Reset();
        EntitlementsStore.Reset();
        BoardStore.Reset();
        await HubService.DisconnectAsync();
        await BoardActionsHubService.DisconnectAsync();
        await MicrosoftAuthNavigation.SwitchMicrosoftAccountAsync(Js, Navigation, AuthState);
    }

    private async Task Logout()
    {
        ProfileStore.Reset();
        EntitlementsStore.Reset();
        BoardStore.Reset();
        await HubService.DisconnectAsync();
        await BoardActionsHubService.DisconnectAsync();
        await MicrosoftAuthNavigation.LocalSignOutAsync(Js, Navigation);
    }

    private sealed record PlanBadge(string Label, string? CssClass);
}
