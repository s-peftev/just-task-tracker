@page "/authentication/{action}"
@layout EmptyLayout
@using JustTaskTracker.WebUI.Infrastructure
@using Microsoft.AspNetCore.Components.WebAssembly.Authentication
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime Js

<RemoteAuthenticatorView Action="@Action"
                         OnLogInSucceeded="HandleLogInSucceeded"
                         OnLogOutSucceeded="HandleLogOutSucceeded" />

@code {
    [Parameter] public string? Action { get; set; }

    private bool _logoutFallbackStarted;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || Action != RemoteAuthenticationActions.LogOutCallback || _logoutFallbackStarted)
            return;

        _logoutFallbackStarted = true;
        await EnsureLogoutRedirectAsync();
    }

    private async Task HandleLogInSucceeded(RemoteAuthenticationState state)
    {
        // Marks this session start as an interactive login so MainLayout calls POST /auth/login
        // (provision + role sync) instead of GET /auth/me. F5 with a cached MSAL session never
        // hits OnLogInSucceeded, so it keeps using /me.
        await Js.InvokeVoidAsync(
            "sessionStorage.setItem",
            MicrosoftAuthNavigation.PendingAppLoginStorageKey,
            "1");
    }

    private async Task HandleLogOutSucceeded(RemoteAuthenticationState state)
    {
        await Js.InvokeVoidAsync("sessionStorage.removeItem", MicrosoftAuthNavigation.LogoutReturnUrlStorageKey);

        var returnUrl = string.IsNullOrWhiteSpace(state.ReturnUrl) ? "/login" : state.ReturnUrl;
        Navigation.NavigateTo(returnUrl, replace: true);
    }

    private async Task EnsureLogoutRedirectAsync()
    {
        // MSAL sometimes completes logout with OperationCompleted and skips OnLogOutSucceeded.
        await Task.Delay(500);

        for (var attempt = 0; attempt < 15; attempt++)
        {
            if (!Navigation.Uri.Contains("logout-callback", StringComparison.OrdinalIgnoreCase))
                return;

            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            if (authState.User.Identity?.IsAuthenticated != true)
            {
                await RedirectAfterLogoutAsync();
                return;
            }

            await Task.Delay(200);
        }

        if (Navigation.Uri.Contains("logout-callback", StringComparison.OrdinalIgnoreCase))
            await RedirectAfterLogoutAsync();
    }

    private async Task RedirectAfterLogoutAsync()
    {
        var returnUrl = await Js.InvokeAsync<string?>(
            "sessionStorage.getItem",
            MicrosoftAuthNavigation.LogoutReturnUrlStorageKey);

        returnUrl = string.IsNullOrWhiteSpace(returnUrl) ? "/login" : returnUrl;

        await Js.InvokeVoidAsync("sessionStorage.removeItem", MicrosoftAuthNavigation.LogoutReturnUrlStorageKey);
        Navigation.NavigateTo(returnUrl, replace: true);
    }
}
