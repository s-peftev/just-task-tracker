@page "/login"
@using JustTaskTracker.WebUI.Infrastructure
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthState

<PageTitle>Log In — JustTaskTracker</PageTitle>

<section class="page-centered login-page">
    <div class="login-page__content">
        <div class="login-page__intro">
            <div class="login-page__brand">
                <img class="login-page__brand-logo"
                     src="favicon.svg"
                     alt=""
                     aria-hidden="true" />
                <span class="login-page__brand-name">JustTaskTracker</span>
            </div>

            <h2 class="login-page__headline">
                <span class="login-page__headline-line">Organize. Track.</span>
                <span class="login-page__headline-line login-page__headline-line--accent">Get things done.</span>
            </h2>
        </div>

        <div class="login-page__stage">
            <img class="login-page__bg"
                 src="login_bg.png"
                 alt=""
                 aria-hidden="true" />
            <p class="login-page__tagline">
                JustTaskTracker helps you and your<br />
                team stay focused, organized and<br />
                in control of what matters.
            </p>
            <div class="login-card">
                <button type="button"
                        class="login-card__button"
                        @onclick="BeginLogin">
                    <img class="login-card__ms-icon"
                         src="microsoft-svgrepo-com.svg"
                         alt=""
                         aria-hidden="true" />
                    <span>Log in with Microsoft</span>
                </button>
            </div>
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = MicrosoftAuthNavigation.AutoSignInQueryParam)]
    public bool AutoSignIn { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/boards");
            return;
        }

        if (AutoSignIn)
            BeginLogin();
    }

    private void BeginLogin() =>
        MicrosoftAuthNavigation.NavigateToMicrosoftLogin(Navigation);
}
