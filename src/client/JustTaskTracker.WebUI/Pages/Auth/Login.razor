@page "/login"
@using JustTaskTracker.WebUI.Infrastructure
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthState

<PageTitle>Log In — JustTaskTracker</PageTitle>

<section class="page-centered page-centered--raised">
    <div class="login-card">
        <h1 class="login-card__title">Log in</h1>
        <MudButton Variant="Variant.Text"
                   Size="Size.Large"
                   FullWidth="true"
                   StartIcon="@Icons.Custom.Brands.Microsoft"
                   Class="btn-glass btn-glass--hero"
                   OnClick="BeginLogin">
            Log in with Microsoft
        </MudButton>
    </div>
</section>

@code {
    [SupplyParameterFromQuery(Name = MicrosoftAuthNavigation.AutoSignInQueryParam)]
    public bool AutoSignIn { get; set; }

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthState.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
        {
            Navigation.NavigateTo("/boards");
            return;
        }

        if (AutoSignIn)
            BeginLogin();
    }

    private void BeginLogin() =>
        MicrosoftAuthNavigation.NavigateToMicrosoftLogin(Navigation);
}
