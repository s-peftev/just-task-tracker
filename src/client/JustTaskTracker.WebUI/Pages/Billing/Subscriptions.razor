@page "/subscriptions"
@attribute [Authorize]
@inherits OwningComponentBase<IBillingStore>
@using JustTaskTracker.WebUI.Domain.Auth
@using JustTaskTracker.WebUI.Domain.Billing
@using JustTaskTracker.WebUI.Infrastructure
@using JustTaskTracker.WebUI.Services.Abstractions.Billing
@using JustTaskTracker.WebUI.Services.Exceptions
@inject IProfileStore ProfileStore
@inject IBillingApiService BillingApiService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

@if (_isAllowed)
{
    <PageTitle>Subscriptions — JustTaskTracker</PageTitle>

    <div class="subscriptions">
        @if (BillingStore.IsLoading && !BillingStore.IsLoaded)
        {
            <div class="page-state">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (BillingStore.ErrorMessage is { } error)
        {
            <div class="page-state">
                <MudAlert Severity="Severity.Error">@error</MudAlert>
            </div>
        }
        else if (BillingStore.IsLoaded)
        {
            <header class="subscriptions__header">
                <p class="subscriptions__eyebrow">Available Plans</p>
                <h1 class="subscriptions__title">Choose the Perfect Plan for Your Needs</h1>
            </header>

            <div class="subscriptions__plans">
                <div class="subscriptions__plans-row">
                @{
                    var subscription = BillingStore.Subscription;
                    var reservePortalSlot = BillingStore.Plans.Any(plan =>
                    {
                        var planAction = PlanCardActionResolver.Resolve(plan, subscription);
                        return planAction?.Kind == PlanCardActionKind.Current
                            && subscription is { HasBillableSubscription: true };
                    });
                }
                @foreach (var plan in BillingStore.Plans)
                {
                    var copy = PlanCopyCatalog.GetOrEmpty(plan.PlanId, plan.Limits);
                    var isCurrentPlan = IsCurrentPlan(plan.PlanId);
                    var statusLabel = isCurrentPlan
                        ? SubscriptionStatusFormatting.TryGetBadgeLabel(subscription?.Status)
                        : null;
                    var statusCss = isCurrentPlan
                        ? SubscriptionStatusFormatting.TryGetBadgeCssModifier(subscription?.Status)
                        : null;
                    var statusNotice = PlanCardSubscriptionNoticeResolver.Resolve(
                        plan.PlanId,
                        subscription,
                        DateTime.UtcNow);
                    var action = PlanCardActionResolver.Resolve(
                        plan,
                        subscription);
                    var showPortalLink = action?.Kind == PlanCardActionKind.Current
                        && subscription is { HasBillableSubscription: true };

                    <PlanCard @key="plan.PlanId" AccentClass="@copy.AccentClass">
                        <div class="plan-card__title-row">
                            <div class="plan-card__title-col">
                                <div class="plan-card__title" role="heading" aria-level="2">@plan.PlanDisplayName</div>
                            </div>
                            @if (statusLabel is not null && statusCss is not null)
                            {
                                <div class="plan-card__status-block">
                                    <div class="plan-card__status @statusCss">@statusLabel</div>
                                    @if (statusNotice is not null)
                                    {
                                        <div class="plan-card__status-note @(statusNotice.Kind == PlanCardSubscriptionNoticeKind.PastDue ? "plan-card__status-note--wrap" : null)">
                                            @statusNotice.Text
                                        </div>
                                    }
                                </div>
                            }
                        </div>

                        <p class="plan-card__price">
                            @if (plan.Price is { } price)
                            {
                                <span class="plan-card__price-amount">@PlanPriceFormatting.FormatAmount(price.UnitAmount, price.Currency)</span>
                                <span class="plan-card__price-interval">@PlanPriceFormatting.FormatInterval(price.Interval)</span>
                            }
                            else
                            {
                                <span class="plan-card__price-amount">@PlanPriceFormatting.FormatFreeAmount()</span>
                                <span class="plan-card__price-interval">@PlanPriceFormatting.FormatFreeInterval()</span>
                            }
                        </p>

                        @if (!string.IsNullOrWhiteSpace(copy.Audience))
                        {
                            <p class="plan-card__audience">@copy.Audience</p>
                        }

                        <div class="plan-card__separator" role="separator"></div>

                        @if (copy.Highlights.Count > 0)
                        {
                            <ul class="plan-card__highlights">
                                @foreach (var highlight in copy.Highlights)
                                {
                                    <li class="plan-card__highlight">
                                        <PlanHighlightIcon Kind="highlight.Icon" />
                                        <span class="plan-card__highlight-text">@highlight.Text</span>
                                    </li>
                                }
                            </ul>
                        }

                        @if (action is not null)
                        {
                            <div class="plan-card__footer">
                                <button type="button"
                                        class="plan-card__action"
                                        disabled="@(!IsActionEnabled(action))"
                                        @onclick="() => OnPlanActionAsync(action, plan.PlanId)">
                                    @action.Label
                                </button>

                                @if (reservePortalSlot)
                                {
                                    <div class="plan-card__portal-slot">
                                        @if (showPortalLink)
                                        {
                                            <a class="plan-card__portal-link"
                                               href="#"
                                               @onclick:preventDefault="true"
                                               @onclick="StartPortalSessionAsync">
                                                Manage billing
                                            </a>
                                        }
                                    </div>
                                }
                            </div>
                        }
                    </PlanCard>
                }
                </div>
            </div>
        }
    </div>
}

@code {
    private bool _isAllowed;
    private bool _pageLoadStarted;
    private bool _isBillingRedirectInProgress;

    private IBillingStore BillingStore => Service;

    protected override void OnInitialized()
    {
        ProfileStore.StateChanged += OnProfileStoreStateChanged;
        BillingStore.StateChanged += OnBillingStoreStateChanged;
        EvaluateAccess();
    }

    protected override async Task OnInitializedAsync()
    {
        if (!_isAllowed)
            return;

        await LoadPageDataAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!_isAllowed || _pageLoadStarted)
            return;

        await LoadPageDataAsync();
    }

    protected override void Dispose(bool disposing)
    {
        if (disposing)
        {
            ProfileStore.StateChanged -= OnProfileStoreStateChanged;
            BillingStore.StateChanged -= OnBillingStoreStateChanged;
        }

        base.Dispose(disposing);
    }

    private void OnProfileStoreStateChanged()
    {
        EvaluateAccess();
        InvokeAsync(async () =>
        {
            if (_isAllowed && !_pageLoadStarted)
                await LoadPageDataAsync();

            StateHasChanged();
        });
    }

    private void OnBillingStoreStateChanged() =>
        InvokeAsync(StateHasChanged);

    private void EvaluateAccess()
    {
        if (!ProfileStore.IsLoaded || ProfileStore.Profile is null)
            return;

        if (!HasUserRole(ProfileStore.Profile))
        {
            _isAllowed = false;
            Navigation.NavigateTo("/not-found", replace: true);
            return;
        }

        _isAllowed = true;
    }

    private async Task LoadPageDataAsync()
    {
        if (_pageLoadStarted || !_isAllowed)
            return;

        _pageLoadStarted = true;
        await BillingStore.EnsureLoadedAsync();
    }

    private bool IsCurrentPlan(string planId) =>
        BillingStore.Subscription is { PlanId: var currentPlanId }
        && planId.Equals(currentPlanId, StringComparison.OrdinalIgnoreCase);

    private bool IsActionEnabled(PlanCardAction action) =>
        action.IsEnabled && !_isBillingRedirectInProgress;

    private async Task OnPlanActionAsync(PlanCardAction action, string planId)
    {
        switch (action.Kind)
        {
            case PlanCardActionKind.Upgrade:
                await StartCheckoutAsync(planId);
                break;
            // ReturnToFree is not wired yet.
        }
    }

    private async Task StartCheckoutAsync(string planId)
    {
        if (_isBillingRedirectInProgress)
            return;

        _isBillingRedirectInProgress = true;

        try
        {
            var session = await BillingApiService.CreateCheckoutSessionAsync(planId);
            Navigation.NavigateTo(session.Url, forceLoad: true);
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
            _isBillingRedirectInProgress = false;
        }
    }

    private async Task StartPortalSessionAsync()
    {
        if (_isBillingRedirectInProgress)
            return;

        _isBillingRedirectInProgress = true;

        try
        {
            var session = await BillingApiService.CreatePortalSessionAsync();
            Navigation.NavigateTo(session.Url, forceLoad: true);
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
            _isBillingRedirectInProgress = false;
        }
    }

    private static bool HasUserRole(UserWithRolesDto profile) =>
        profile.Roles.Any(r => r.Equals("User", StringComparison.OrdinalIgnoreCase));
}
