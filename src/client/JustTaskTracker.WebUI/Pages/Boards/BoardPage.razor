@page "/boards/{Id:guid}"
@page "/boards/{Id:guid}/columns/{ColumnId:guid}/tasks/{TaskId:guid}"
@attribute [Authorize]
@implements IAsyncDisposable
@using JustTaskTracker.WebUI.Infrastructure
@using JustTaskTracker.WebUI.Domain.Boards.Authorization
@using JustTaskTracker.WebUI.Services.Abstractions.Boards
@using JustTaskTracker.WebUI.Services.Exceptions
@using BlazorSortable
@using Microsoft.JSInterop
@inject IBoardApiService BoardApiService
@inject IBoardDetailsStore BoardDetailsStore
@inject IBoardTaskStore BoardTaskStore
@inject IBoardTaskSearchStore BoardTaskSearchStore
@inject IBoardMembersStore BoardMembersStore
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>@GetPageTitle()</PageTitle>

<div class="board-page @(_taskOnlyMode ? "board-page--task-only" : null) @(_isFooterTrayOpen ? "board-page--footer-open" : null)">
    @if (_renderBoard)
    {
        @if (BoardDetailsStore.IsLoading && BoardDetailsStore.Board is null)
        {
            <div class="page-state page-state--stacked">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
        else if (BoardDetailsStore.ErrorMessage is { } error)
        {
            <div class="page-state page-state--stacked">
                <MudAlert Severity="Severity.Error">@error</MudAlert>
                <button type="button" class="btn-noir" @onclick="GoToDashboard">
                    <span>Back to dashboard</span>
                </button>
            </div>
        }
        else if (BoardDetailsStore.Board is { } board)
        {
            <header class="board-page__header">
                <div class="board-page__title-area">
                    @if (_isEditingName)
                    {
                        <div class="board-page__title-field">
                            <span class="board-page__title-sizer">@_editName</span>
                            <input @ref="_titleInputRef"
                                   class="board-page__title-input"
                                   type="text"
                                   maxlength="100"
                                   @bind="_editName"
                                   @bind:event="oninput"
                                   @onkeydown="OnTitleKeyDownAsync"
                                   @onblur="OnTitleBlurAsync" />
                        </div>
                    }
                    else if (CanRenameBoard)
                    {
                        <h1 class="text-section-title board-page__title board-page__title--editable"
                            @onclick="StartNameEdit">
                            @board.Name
                        </h1>
                    }
                    else
                    {
                        <h1 class="text-section-title board-page__title">@board.Name</h1>
                    }
                </div>

                <div class="board-page__controls">
                    <BoardPageMenu UserRole="board.UserRole"
                                   OnMembersClick="OpenMembersOverlayAsync"
                                   OnLeaveBoardClick="LeaveBoardAsync"
                                   OnDeleteBoardClick="DeleteBoardAsync" />

                    <button type="button"
                            class="btn-icon btn-icon--round btn-icon--sm"
                            aria-label="Back to dashboard"
                            @onclick="GoToDashboard">
                        <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                            <path d="M18 6L6 18M6 6l12 12"
                                  stroke="currentColor"
                                  stroke-width="2"
                                  stroke-linecap="round" />
                        </svg>
                    </button>
                </div>
            </header>

            <section @ref="_contentRef" class="board-page__content">
                <div @ref="_scrollBodyRef" class="board-page__body">
                    <Sortable TItem="ColumnDto"
                              Items="_sortableColumns"
                              ItemKeySelector="GetColumnKey"
                              Handle=".board-column__header--draggable"
                              Filter=".board-column__delete, .board-column__title-field, .board-column__title-input, .board-column__add-task, .board-column__add-task-input, .board-task-card"
                              Delay="0"
                              DelayOnTouchOnly="true"
                              FallbackTolerance="5"
                              Disabled="@(!CanManageColumns || _isReorderingColumns)"
                              Class="board-page__columns-sortable"
                              GhostClass="board-page__column-ghost"
                              DragClass="board-page__column-drag"
                              Scroll="false"
                              OnUpdate="OnColumnsReorderedAsync">
                        <div class="board-page__column-item @GetColumnTrayOverlapClass(context.Id)">
                            <BoardColumn Column="@context"
                                         UserRole="board.UserRole" />
                        </div>
                    </Sortable>

                    @if (CanManageColumns)
                    {
                        <div class="board-page__column-slot">
                            <button type="button"
                                    class="btn-glass-white board-page__add-column-btn"
                                    @onclick="CreateColumnAsync">
                                + Add column
                            </button>
                        </div>
                    }
                </div>
            </section>

            <footer class="board-page__footer">
                <div class="board-page__footer-drawer">
                    <div @ref="_footerPanelRef" class="board-page__footer-panel">
                        <div class="board-page__footer-tab">
                            <button type="button"
                                    class="board-page__footer-handle"
                                    aria-label="@(_isFooterTrayOpen ? "Close search" : "Open search")"
                                    aria-expanded="@_isFooterTrayOpen"
                                    @onclick="ToggleFooterTray">
                                <svg class="board-page__footer-handle-icon"
                                     viewBox="0 0 24 24"
                                     aria-hidden="true"
                                     focusable="false">
                                    <circle cx="11"
                                            cy="11"
                                            r="6"
                                            stroke="currentColor"
                                            stroke-width="2"
                                            fill="none" />
                                    <path d="M16 16l5 5"
                                          stroke="currentColor"
                                          stroke-width="2"
                                          stroke-linecap="round" />
                                </svg>
                            </button>
                        </div>

                        <div class="board-page__footer-tray">
                            @if (BoardTaskSearchStore.IsOpen)
                            {
                                <BoardTaskSearchOverlay />
                            }

                            <input class="board-page__footer-search-input"
                                   type="search"
                                   aria-label="Search tasks"
                                   placeholder="Search tasks"
                                   value="@BoardTaskSearchStore.SearchText"
                                   @onfocus="OnFooterSearchFocusAsync"
                                   @onblur="OnFooterSearchBlurAsync"
                                   @oninput="OnFooterSearchInputAsync" />
                        </div>
                    </div>
                </div>
            </footer>
        }
    }

    @if (BoardMembersStore.IsOpen)
    {
        <BoardMembersOverlay />
    }

    @if (TaskId is { } taskId && ColumnId is { } columnId)
    {
        <BoardTaskDetailsOverlay @key="taskId"
                                 BoardId="Id"
                                 ColumnId="columnId"
                                 TaskId="taskId"
                                 DimBackground="_renderBoard"
                                 OnClose="CloseTaskAsync" />
    }
</div>

@code {
    [Parameter]
    public Guid Id { get; set; }

    [Parameter]
    public Guid? ColumnId { get; set; }

    [Parameter]
    public Guid? TaskId { get; set; }

    private bool _renderBoard = true;
    private bool _taskOnlyMode;
    private bool _deferBoardLoadUntilTaskClose;
    private bool _isEditingName;
    private bool _isSavingName;
    private bool _isReorderingColumns;
    private bool _focusTitleInput;
    private string _editName = string.Empty;
    private ElementReference _titleInputRef;
    private ElementReference _contentRef;
    private ElementReference _scrollBodyRef;
    private ElementReference _footerPanelRef;
    private readonly List<ColumnDto> _sortableColumns = [];
    private readonly HashSet<Guid> _trayOverlappingColumnIds = [];
    private IJSObjectReference? _panScrollModule;
    private IJSObjectReference? _panScrollHandle;
    private IJSObjectReference? _trayOverlapModule;
    private IJSObjectReference? _trayOverlapHandle;
    private DotNetObjectReference<BoardPage>? _trayOverlapDotNetRef;
    private bool _panScrollAttached;
    private bool _isFooterTrayOpen;
    private bool _suppressSearchBlurClose;
    private Guid _searchStoreBoardId;
    private Guid _membersStoreBoardId;

    private bool CanRenameBoard =>
        BoardDetailsStore.Board is { UserRole: var role } && BoardRolePermissions.CanRenameBoard(role);

    private bool CanManageColumns =>
        BoardDetailsStore.Board is { UserRole: var role } && BoardRolePermissions.CanManageColumns(role);

    protected override void OnInitialized()
    {
        BoardDetailsStore.StateChanged += OnBoardStoreStateChanged;
        BoardTaskStore.StateChanged += OnTaskStoreStateChanged;
        BoardTaskSearchStore.StateChanged += OnTaskSearchStoreStateChanged;
        BoardMembersStore.StateChanged += OnMembersStoreStateChanged;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_searchStoreBoardId != Guid.Empty && _searchStoreBoardId != Id)
            BoardTaskSearchStore.Reset();

        if (_membersStoreBoardId != Guid.Empty && _membersStoreBoardId != Id)
            BoardMembersStore.Reset();

        _searchStoreBoardId = Id;
        _membersStoreBoardId = Id;
        await UpdateRouteStateAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_focusTitleInput)
        {
            _focusTitleInput = false;
            await _titleInputRef.FocusAsync();
        }

        if (_renderBoard && BoardDetailsStore.Board is not null && !_panScrollAttached)
            await EnsurePanScrollAttachedAsync();

        if (_renderBoard && _isFooterTrayOpen)
            await EnsureTrayOverlapObserverAsync();
    }

    public async ValueTask DisposeAsync()
    {
        BoardDetailsStore.StateChanged -= OnBoardStoreStateChanged;
        BoardTaskStore.StateChanged -= OnTaskStoreStateChanged;
        BoardTaskSearchStore.StateChanged -= OnTaskSearchStoreStateChanged;
        BoardTaskSearchStore.Reset();
        BoardMembersStore.StateChanged -= OnMembersStoreStateChanged;
        BoardMembersStore.Reset();
        await DisposeTrayOverlapObserverAsync();

        if (_panScrollHandle is not null)
        {
            await _panScrollHandle.InvokeVoidAsync("dispose");
            await _panScrollHandle.DisposeAsync();
        }

        if (_panScrollModule is not null)
            await _panScrollModule.DisposeAsync();

        _trayOverlapDotNetRef?.Dispose();
    }

    [JSInvokable]
    public void SetTrayOverlappingColumnIds(string[] columnIds)
    {
        var updatedIds = columnIds
            .Select(Guid.Parse)
            .ToHashSet();

        if (_trayOverlappingColumnIds.SetEquals(updatedIds))
            return;

        _trayOverlappingColumnIds.Clear();

        foreach (var id in updatedIds)
            _trayOverlappingColumnIds.Add(id);

        InvokeAsync(StateHasChanged);
    }

    private string? GetColumnTrayOverlapClass(Guid columnId) =>
        _isFooterTrayOpen && _trayOverlappingColumnIds.Contains(columnId)
            ? "board-page__column-item--tray-overlap"
            : null;

    private async Task EnsureTrayOverlapObserverAsync()
    {
        if (!_renderBoard || !_isFooterTrayOpen)
            return;

        _trayOverlapModule ??= await Js.InvokeAsync<IJSObjectReference>(
            "import",
            "./js/boardFooterTrayOverlap.js");
        _trayOverlapDotNetRef ??= DotNetObjectReference.Create(this);

        if (_trayOverlapHandle is not null)
            return;

        _trayOverlapHandle = await _trayOverlapModule.InvokeAsync<IJSObjectReference>(
            "attach",
            _scrollBodyRef,
            _footerPanelRef,
            _trayOverlapDotNetRef);
    }

    private async Task DisposeTrayOverlapObserverAsync()
    {
        if (_trayOverlapHandle is not null)
        {
            await _trayOverlapHandle.InvokeVoidAsync("dispose");
            await _trayOverlapHandle.DisposeAsync();
            _trayOverlapHandle = null;
        }

        if (_trayOverlappingColumnIds.Count > 0)
        {
            _trayOverlappingColumnIds.Clear();
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task OnFooterTrayToggledAsync()
    {
        if (_isFooterTrayOpen)
        {
            await InvokeAsync(StateHasChanged);
            await EnsureTrayOverlapObserverAsync();
            await Task.Delay(260);
            if (_trayOverlapHandle is not null)
                await _trayOverlapHandle.InvokeVoidAsync("refresh");
            return;
        }

        await DisposeTrayOverlapObserverAsync();
    }

    private async Task UpdateRouteStateAsync()
    {
        if (TaskId is null || ColumnId is null)
        {
            if (_deferBoardLoadUntilTaskClose)
            {
                _deferBoardLoadUntilTaskClose = false;
                _renderBoard = true;
                _taskOnlyMode = false;
                await BoardDetailsStore.LoadAsync(Id);
                SyncSortableColumnsFromStore();
                return;
            }

            _taskOnlyMode = false;
            _renderBoard = true;
            await BoardDetailsStore.LoadAsync(Id);
            SyncSortableColumnsFromStore();
            return;
        }

        if (BoardDetailsStore.BoardId == Id && BoardDetailsStore.Board is not null)
        {
            _renderBoard = true;
            _taskOnlyMode = false;
        }
        else
        {
            _renderBoard = false;
            _taskOnlyMode = true;
            _deferBoardLoadUntilTaskClose = true;
        }

        SyncSortableColumnsFromStore();
    }

    private string GetPageTitle()
    {
        if (TaskId is not null && BoardTaskStore.Task is { } task)
            return $"{task.Title} — JustTaskTracker";

        if (BoardDetailsStore.Board is { } board)
            return $"{board.Name} — JustTaskTracker";

        return "Board — JustTaskTracker";
    }

    private void CloseTaskAsync() =>
        Navigation.NavigateTo(BoardTaskRoutes.GetBoardUrl(Id));

    private async Task EnsurePanScrollAttachedAsync()
    {
        _panScrollModule ??= await Js.InvokeAsync<IJSObjectReference>("import", "./js/boardPanScroll.js");
        _panScrollHandle = await _panScrollModule.InvokeAsync<IJSObjectReference>(
            "attach",
            _contentRef,
            _scrollBodyRef);
        _panScrollAttached = true;
    }

    private void OnBoardStoreStateChanged()
    {
        SyncSortableColumnsFromStore();
        InvokeAsync(StateHasChanged);
    }

    private void OnTaskStoreStateChanged() =>
        InvokeAsync(StateHasChanged);

    private void OnTaskSearchStoreStateChanged() =>
        InvokeAsync(StateHasChanged);

    private void OnMembersStoreStateChanged() =>
        InvokeAsync(StateHasChanged);

    private void SyncSortableColumnsFromStore()
    {
        if (BoardDetailsStore.Board is null)
        {
            _sortableColumns.Clear();
            return;
        }

        var ordered = BoardDetailsStore.Board.Columns
            .OrderBy(column => column.Position)
            .ToList();

        if (_sortableColumns.Count == ordered.Count
            && _sortableColumns.Zip(ordered).All(pair => pair.First.Id == pair.Second.Id))
        {
            for (var i = 0; i < ordered.Count; i++)
                _sortableColumns[i] = ordered[i];

            return;
        }

        _sortableColumns.Clear();
        _sortableColumns.AddRange(ordered);
    }

    private static string GetColumnKey(ColumnDto column) => column.Id.ToString();

    private async Task OnColumnsReorderedAsync(SortableEventArgs<ColumnDto> args)
    {
        if (!CanManageColumns || _isReorderingColumns)
            return;

        if (args.OldIndex == args.NewIndex)
            return;

        _isReorderingColumns = true;

        try
        {
            await BoardDetailsStore.ReorderColumnAsync(args.Item.Id, args.NewIndex);
        }
        catch (ApiServiceException ex)
        {
            SyncSortableColumnsFromStore();
            Snackbar.ShowApiError(ex);
        }
        finally
        {
            _isReorderingColumns = false;

            if (_isFooterTrayOpen && _trayOverlapHandle is not null)
                await _trayOverlapHandle.InvokeVoidAsync("refresh");
        }
    }

    private void GoToDashboard() => Navigation.NavigateTo("/dashboard");

    private async Task ToggleFooterTray()
    {
        _isFooterTrayOpen = !_isFooterTrayOpen;

        if (!_isFooterTrayOpen)
            BoardTaskSearchStore.Close();

        await OnFooterTrayToggledAsync();
    }

    private async Task OnFooterSearchFocusAsync()
    {
        if (!_isFooterTrayOpen)
            await ToggleFooterTray();

        if (BoardTaskSearchStore.IsOpen)
            return;

        if (BoardDetailsStore.Board is not { } board)
            return;

        var columnId = board.Columns
            .OrderBy(column => column.Position)
            .Select(column => column.Id)
            .FirstOrDefault();

        // columnId is required by the route even though lookup is board-scoped on the backend.
        if (columnId == Guid.Empty)
        {
            Snackbar.Add("No columns available for task search.", Severity.Info);
            return;
        }

        _suppressSearchBlurClose = true;

        try
        {
            await BoardTaskSearchStore.OpenAsync(Id, columnId);
        }
        finally
        {
            _suppressSearchBlurClose = false;
        }
    }

    private void OnFooterSearchBlurAsync()
    {
        if (_suppressSearchBlurClose)
            return;

        BoardTaskSearchStore.Close();
    }

    private Task OnFooterSearchInputAsync(ChangeEventArgs e) =>
        BoardTaskSearchStore.SetSearchAsync(e.Value?.ToString() ?? string.Empty);

    private async Task OpenMembersOverlayAsync()
    {
        if (BoardDetailsStore.Board is not { } board)
            return;

        if (!BoardRolePermissions.CanViewBoard(board.UserRole))
            return;

        try
        {
            await BoardMembersStore.OpenAsync(Id, board.UserRole);
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
    }

    private async Task LeaveBoardAsync()
    {
        var message =
            $"Leave board \"{BoardDetailsStore.Board?.Name}\"?{Environment.NewLine}You will lose access to this board.";

        var dialog = await DialogService.ShowConfirmResourceAsync(
            "Leave board",
            message,
            confirmLabel: "Leave",
            submitButtonClass: "btn-glass btn-dialog-action");

        var result = await dialog.Result;

        if (result is not { Canceled: false, Data: true })
            return;

        try
        {
            await BoardApiService.LeaveBoardAsync(Id);
            Snackbar.Add("You left the board.", Severity.Success);
            Navigation.NavigateTo("/dashboard");
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
    }

    private async Task CreateColumnAsync()
    {
        var dialog = await DialogService.ShowResourceFormAsync(
            "Create new column",
            "Create",
            CreateColumnForm.FormId,
            CreateColumnForm.Render());
        var result = await dialog.Result;

        if (result is not { Canceled: false, Data: string name })
            return;

        try
        {
            var column = await BoardDetailsStore.CreateColumnAsync(name);
            Snackbar.Add($"Column \"{column.Name}\" created.", Severity.Success);
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
    }

    private void StartNameEdit()
    {
        if (!CanRenameBoard || BoardDetailsStore.Board is null || _isEditingName)
            return;

        _editName = BoardDetailsStore.Board.Name;
        _isEditingName = true;
        _focusTitleInput = true;
    }

    private void CancelNameEdit()
    {
        _isEditingName = false;
        _editName = BoardDetailsStore.Board?.Name ?? string.Empty;
    }

    private async Task OnTitleKeyDownAsync(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await SaveBoardNameAsync();
        else if (e.Key == "Escape")
            CancelNameEdit();
    }

    private async Task OnTitleBlurAsync()
    {
        if (!_isEditingName)
            return;

        await SaveBoardNameAsync();
    }

    private async Task SaveBoardNameAsync()
    {
        if (!_isEditingName || BoardDetailsStore.Board is null || _isSavingName)
            return;

        var trimmedName = _editName.Trim();

        if (string.IsNullOrEmpty(trimmedName))
        {
            Snackbar.Add("Board name is required.", Severity.Error);
            return;
        }

        if (trimmedName.Length > 100)
        {
            Snackbar.Add("Board name must not exceed 100 characters.", Severity.Error);
            return;
        }

        if (string.Equals(trimmedName, BoardDetailsStore.Board.Name, StringComparison.Ordinal))
        {
            CancelNameEdit();
            return;
        }

        _isSavingName = true;

        try
        {
            await BoardApiService.UpdateBoardAsync(Id, trimmedName);
            BoardDetailsStore.UpdateBoardName(trimmedName);
            _isEditingName = false;
            Snackbar.Add("Board updated.", Severity.Success);
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
        finally
        {
            _isSavingName = false;
        }
    }

    private async Task DeleteBoardAsync()
    {
        var message =
            $"Delete board \"{BoardDetailsStore.Board?.Name}\"?{Environment.NewLine}This action cannot be undone.";

        var dialog = await DialogService.ShowConfirmResourceAsync(
            "Delete board",
            message,
            confirmLabel: "Delete");

        var result = await dialog.Result;

        if (result is not { Canceled: false, Data: true })
            return;

        try
        {
            await BoardApiService.DeleteBoardAsync(Id);
            Snackbar.Add("Board deleted.", Severity.Success);
            Navigation.NavigateTo("/dashboard");
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
    }
}
