@page "/boards"
@attribute [Authorize]
@implements IAsyncDisposable
@using JustTaskTracker.WebUI.Infrastructure
@using JustTaskTracker.WebUI.Domain.Boards.Authorization
@using JustTaskTracker.WebUI.Services.Abstractions.Boards
@using JustTaskTracker.WebUI.Services.Abstractions.Hubs
@using JustTaskTracker.WebUI.Services.Exceptions
@inject IBoardStore BoardStore
@inject IBoardApiService BoardApiService
@inject IBoardExportStatusHubService HubService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation
@inject IJSRuntime Js

<PageTitle>Boards — JustTaskTracker</PageTitle>

<div class="boards">
    <section class="boards__section">
        <header class="boards__header">
            <h2 class="text-section-title">Active boards</h2>
            <div class="boards__search-row">
                <input class="boards__search-input boards__search-input--active"
                       type="search"
                       maxlength="40"
                       placeholder="Search boards by name"
                       value="@BoardStore.Active.SearchText"
                       @oninput="OnActiveSearchInputAsync" />
                <button type="button"
                        class="boards__archived-toggle @(_showArchivedBoards ? "boards__archived-toggle--active" : null)"
                        aria-pressed="@_showArchivedBoards"
                        aria-label="Show archived boards"
                        @onclick="ToggleShowArchivedBoardsAsync">
                    <svg class="boards__archived-toggle-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M20.54 5.23l-1.39-1.68C18.88 3.21 18.47 3 18 3H6c-.47 0-.88.21-1.16.55L3.46 5.23C3.17 5.57 3 6.02 3 6.5V19c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V6.5c0-.48-.17-.93-.46-1.27zM12 17.5 6.5 12H10v-2h4v2h3.5L12 17.5zM5.12 5l.81-1h12l.94 1H5.12z"
                              fill="currentColor" />
                    </svg>
                    <span class="boards__archived-toggle-tooltip" aria-hidden="true">Show archived boards</span>
                </button>
                <button type="button"
                        class="boards__owned-filter @(_showOwnedOnly ? "boards__owned-filter--active" : null)"
                        aria-pressed="@_showOwnedOnly"
                        aria-label="Show only boards I created"
                        @onclick="ToggleShowOwnedOnlyAsync">
                    <svg class="boards__owned-filter-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"
                              fill="currentColor" />
                    </svg>
                    <span class="boards__owned-filter-tooltip" aria-hidden="true">Show only boards I created</span>
                </button>
                @if (CanCreateBoard)
                {
                    @if (IsBoardCreateLimitReached)
                    {
                        <HoverTooltip>
                            <Trigger>
                                <button type="button"
                                        class="boards__create-button boards__create-button--disabled"
                                        aria-label="Create new board"
                                        disabled
                                        @onclick="CreateBoardAsync">
                                    <svg class="boards__create-button-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                        <path d="M12 5v14M5 12h14"
                                              fill="none"
                                              stroke="currentColor"
                                              stroke-width="3"
                                              stroke-linecap="round" />
                                    </svg>
                                </button>
                            </Trigger>
                            <ChildContent>
                                <p class="hover-tooltip__panel-text">
                                    You've reached the board limit for your plan. Upgrade your plan to create more boards.
                                </p>
                                <button type="button"
                                        class="hover-tooltip__action"
                                        @onclick="GoToSubscriptions">
                                    View subscriptions
                                </button>
                            </ChildContent>
                        </HoverTooltip>
                    }
                    else
                    {
                        <button type="button"
                                class="boards__create-button"
                                aria-label="Create new board"
                                title="Create new board"
                                @onclick="CreateBoardAsync">
                            <svg class="boards__create-button-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                                <path d="M12 5v14M5 12h14"
                                      fill="none"
                                      stroke="currentColor"
                                      stroke-width="3"
                                      stroke-linecap="round" />
                            </svg>
                        </button>
                    }
                }
                @if (BoardLimitLabel is { } boardLimitLabel)
                {
                    <span class="boards__board-limit @(IsBoardCreateLimitReached ? "boards__board-limit--reached" : null)"
                          title="Active boards used / plan limit">
                        <span class="boards__board-limit-value">@boardLimitLabel</span>
                        <span class="boards__board-limit-caption">board limit</span>
                    </span>
                }
            </div>
            <div class="boards__pager">
                <button type="button"
                        class="btn-noir"
                        disabled="@(BoardStore.Active.CurrentPage <= 1 || BoardStore.Active.IsLoading)"
                        @onclick="() => ChangeActivePageAsync(BoardStore.Active.CurrentPage - 1)">
                    <span>Prev</span>
                </button>
                <span class="text-meta-subtle">
                    Page @BoardStore.Active.CurrentPage of @(Math.Max(BoardStore.Active.Pagination.TotalPages, 1))
                </span>
                <button type="button"
                        class="btn-noir"
                        disabled="@(BoardStore.Active.CurrentPage >= Math.Max(BoardStore.Active.Pagination.TotalPages, 1) || BoardStore.Active.IsLoading)"
                        @onclick="() => ChangeActivePageAsync(BoardStore.Active.CurrentPage + 1)">
                    <span>Next</span>
                </button>
            </div>
        </header>

        <div class="boards__boards">
            @if (BoardStore.Active.IsLoading && BoardStore.Active.Boards.Count == 0)
            {
                <div class="page-state">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                </div>
            }
            else if (BoardStore.Active.ErrorMessage is { } activeError)
            {
                <div class="page-state">
                    <MudAlert Severity="Severity.Error">@activeError</MudAlert>
                </div>
            }
            else if (BoardStore.Active.Boards.Count == 0)
            {
                <div class="page-state">
                    <p class="text-empty">You don't have any boards yet.</p>
                </div>
            }
            else
            {
                <div class="boards__grid">
                    @foreach (var board in BoardStore.Active.Boards)
                    {
                        <BoardCard Board="board" OnClick="OpenBoard" />
                    }
                </div>
            }
        </div>
    </section>

    @if (_showArchivedBoards)
    {
        <hr class="boards__divider" />

        <section class="boards__section">
            <header class="boards__header">
                <h2 class="text-section-title">Archived boards</h2>
                <input class="boards__search-input boards__search-input--archived"
                       type="search"
                       maxlength="40"
                       placeholder="Search boards by name"
                       value="@BoardStore.Archived.SearchText"
                       @oninput="OnArchivedSearchInputAsync" />
                <div class="boards__pager">
                    <button type="button"
                            class="btn-noir"
                            disabled="@(BoardStore.Archived.CurrentPage <= 1 || BoardStore.Archived.IsLoading)"
                            @onclick="() => ChangeArchivedPageAsync(BoardStore.Archived.CurrentPage - 1)">
                        <span>Prev</span>
                    </button>
                    <span class="text-meta-subtle">
                        Page @BoardStore.Archived.CurrentPage of @(Math.Max(BoardStore.Archived.Pagination.TotalPages, 1))
                    </span>
                    <button type="button"
                            class="btn-noir"
                            disabled="@(BoardStore.Archived.CurrentPage >= Math.Max(BoardStore.Archived.Pagination.TotalPages, 1) || BoardStore.Archived.IsLoading)"
                            @onclick="() => ChangeArchivedPageAsync(BoardStore.Archived.CurrentPage + 1)">
                        <span>Next</span>
                    </button>
                </div>
            </header>

            <div class="boards__boards">
                @if (BoardStore.Archived.IsLoading && BoardStore.Archived.Boards.Count == 0)
                {
                    <div class="page-state">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    </div>
                }
                else if (BoardStore.Archived.ErrorMessage is { } archivedError)
                {
                    <div class="page-state">
                        <MudAlert Severity="Severity.Error">@archivedError</MudAlert>
                    </div>
                }
                else if (BoardStore.Archived.Boards.Count == 0)
                {
                    <div class="page-state">
                        <p class="text-empty">You don't have any archived boards.</p>
                    </div>
                }
                else
                {
                    <div class="boards__grid">
                        @foreach (var board in BoardStore.Archived.Boards)
                        {
                            <BoardCard Board="board" OnClick="OpenBoard" />
                        }
                    </div>
                }
            </div>
        </section>
    }
</div>

@code {
    private const string ShowArchivedBoardsStorageKey = "jtt.showArchivedBoards";
    private const string ShowOwnedOnlyStorageKey = "jtt.showOwnedOnlyBoards";

    private IReadOnlyList<Guid> _subscribedArchivedBoardIds = [];
    private bool _showArchivedBoards = true;
    private bool _showOwnedOnly;
    private bool _preferenceLoaded;

    private bool CanCreateBoard =>
        ProfileStore.Profile?.Roles.Any(r =>
            r.Equals("Admin", StringComparison.OrdinalIgnoreCase) ||
            r.Equals("User", StringComparison.OrdinalIgnoreCase)) ?? false;

    private bool ShowBoardLimitCounter =>
        ProfileStore.Profile is { Roles: var roles }
        && roles.Any(r => r.Equals("User", StringComparison.OrdinalIgnoreCase))
        && !roles.Any(r =>
            r.Equals("Admin", StringComparison.OrdinalIgnoreCase)
            || r.Equals("Guest", StringComparison.OrdinalIgnoreCase));

    private int? MaxBoardsLimit =>
        ShowBoardLimitCounter
            ? EntitlementsStore.Entitlements?.Limits.MaxBoards
            : null;

    private int ActiveBoardUsageCount => BoardStore.ActiveOwnedBoardsCount ?? 0;

    private string? BoardLimitLabel =>
        MaxBoardsLimit is int max
            ? $"{ActiveBoardUsageCount} / {max}"
            : null;

    private bool IsBoardCreateLimitReached =>
        MaxBoardsLimit is int max
        && BoardStore.ActiveOwnedBoardsCount is int count
        && count >= max;

    [Inject]
    private IProfileStore ProfileStore { get; set; } = default!;

    [Inject]
    private IEntitlementsStore EntitlementsStore { get; set; } = default!;

    protected override async Task OnInitializedAsync()
    {
        BoardStore.StateChanged += OnStoreStateChanged;
        ProfileStore.StateChanged += OnProfileStoreStateChanged;
        EntitlementsStore.StateChanged += OnEntitlementsStoreStateChanged;
        _showArchivedBoards = await ReadShowArchivedBoardsPreferenceAsync();
        _showOwnedOnly = await ReadShowOwnedOnlyPreferenceAsync();
        BoardStore.SyncIsOwnedFilter(_showOwnedOnly ? true : null);
        _preferenceLoaded = true;
    }

    protected override Task OnParametersSetAsync() =>
        TryRefreshBoardsAsync();

    private async Task TryRefreshBoardsAsync()
    {
        if (!_preferenceLoaded || !ProfileStore.IsLoaded || ProfileStore.RequiresLogin)
            return;

        if (BoardStore.Active.IsLoading)
            return;

        if (_showArchivedBoards && BoardStore.Archived.IsLoading)
            return;

        await BoardStore.RefreshAsync(includeArchived: _showArchivedBoards);
    }

    private void OpenBoard(BoardLookupDto board) =>
        Navigation.NavigateTo($"/boards/{board.Id}");

    private Task ChangeActivePageAsync(int pageNumber) =>
        BoardStore.LoadActiveAsync(pageNumber);

    private Task ChangeArchivedPageAsync(int pageNumber) =>
        BoardStore.LoadArchivedAsync(pageNumber);

    private Task OnActiveSearchInputAsync(ChangeEventArgs e) =>
        BoardStore.SetActiveSearchAsync(e.Value?.ToString() ?? string.Empty);

    private Task OnArchivedSearchInputAsync(ChangeEventArgs e) =>
        BoardStore.SetArchivedSearchAsync(e.Value?.ToString() ?? string.Empty);

    private async Task ToggleShowArchivedBoardsAsync()
    {
        _showArchivedBoards = !_showArchivedBoards;
        await PersistShowArchivedBoardsPreferenceAsync(_showArchivedBoards);

        if (_showArchivedBoards)
        {
            await BoardStore.LoadArchivedAsync(1);
            return;
        }

        await SyncArchivedHubSubscriptionsAsync(Array.Empty<Guid>());
        BoardStore.ResetArchived();
    }

    private async Task ToggleShowOwnedOnlyAsync()
    {
        _showOwnedOnly = !_showOwnedOnly;
        await PersistShowOwnedOnlyPreferenceAsync(_showOwnedOnly);
        await BoardStore.SetIsOwnedFilterAsync(
            _showOwnedOnly ? true : null,
            includeArchived: _showArchivedBoards);
    }

    private async Task<bool> ReadShowArchivedBoardsPreferenceAsync()
    {
        try
        {
            var stored = await Js.InvokeAsync<string?>("localStorage.getItem", ShowArchivedBoardsStorageKey);
            // Default ON when unset — matches previous always-visible archived section.
            if (string.IsNullOrWhiteSpace(stored))
                return true;

            return stored is "1" or "true";
        }
        catch (JSException)
        {
            return true;
        }
    }

    private async Task PersistShowArchivedBoardsPreferenceAsync(bool showArchived)
    {
        try
        {
            await Js.InvokeVoidAsync(
                "localStorage.setItem",
                ShowArchivedBoardsStorageKey,
                showArchived ? "1" : "0");
        }
        catch (JSException)
        {
            // Preference is best-effort; UI state still applies for this session.
        }
    }

    private async Task<bool> ReadShowOwnedOnlyPreferenceAsync()
    {
        try
        {
            var stored = await Js.InvokeAsync<string?>("localStorage.getItem", ShowOwnedOnlyStorageKey);
            if (string.IsNullOrWhiteSpace(stored))
                return false;

            return stored is "1" or "true";
        }
        catch (JSException)
        {
            return false;
        }
    }

    private async Task PersistShowOwnedOnlyPreferenceAsync(bool showOwnedOnly)
    {
        try
        {
            await Js.InvokeVoidAsync(
                "localStorage.setItem",
                ShowOwnedOnlyStorageKey,
                showOwnedOnly ? "1" : "0");
        }
        catch (JSException)
        {
            // Preference is best-effort; UI state still applies for this session.
        }
    }

    private async Task CreateBoardAsync()
    {
        if (IsBoardCreateLimitReached)
            return;

        var dialog = await DialogService.ShowResourceFormAsync(
            "Create new board",
            "Create",
            CreateBoardForm.FormId,
            CreateBoardForm.Render());
        var result = await dialog.Result;

        if (result is not { Canceled: false, Data: string name })
            return;

        try
        {
            var board = await BoardApiService.CreateBoardAsync(name);

            Snackbar.Add($"Board \"{board.Name}\" created.", Severity.Success);
            Navigation.NavigateTo($"/boards/{board.Id}");
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
    }

    private void GoToSubscriptions() =>
        Navigation.NavigateTo("/subscriptions");

    public async ValueTask DisposeAsync()
    {
        BoardStore.StateChanged -= OnStoreStateChanged;
        ProfileStore.StateChanged -= OnProfileStoreStateChanged;
        EntitlementsStore.StateChanged -= OnEntitlementsStoreStateChanged;
        await SyncArchivedHubSubscriptionsAsync(Array.Empty<Guid>());
    }

    private void OnStoreStateChanged() =>
        InvokeAsync(async () =>
        {
            if (_showArchivedBoards)
                await SyncArchivedHubSubscriptionsAsync();
            StateHasChanged();
        });

    private void OnProfileStoreStateChanged() =>
        InvokeAsync(async () =>
        {
            await TryRefreshBoardsAsync();
            StateHasChanged();
        });

    private void OnEntitlementsStoreStateChanged() =>
        InvokeAsync(StateHasChanged);

    private async Task SyncArchivedHubSubscriptionsAsync(
        IReadOnlyList<Guid>? overrideNewIds = null)
    {
        var newIds = overrideNewIds
            ?? (BoardStore.Archived.IsLoaded && !BoardStore.Archived.IsLoading
                ? BoardStore.Archived.Boards
                    .Where(b => BoardRolePermissions.CanExportBoard(b.UserRole))
                    .Select(b => b.Id)
                    .ToList()
                : null);

        if (newIds is null)
            return;

        var toUnsubscribe = _subscribedArchivedBoardIds.Except(newIds).ToList();
        var toSubscribe = newIds.Except(_subscribedArchivedBoardIds).ToList();

        if (toUnsubscribe.Count > 0)
            await HubService.UnsubscribeAsync(toUnsubscribe);

        if (toSubscribe.Count > 0)
            await HubService.SubscribeAsync(toSubscribe);

        _subscribedArchivedBoardIds = newIds;
    }
}
