@page "/boards"
@attribute [Authorize]
@implements IDisposable
@using JustTaskTracker.WebUI.Infrastructure
@using JustTaskTracker.WebUI.Services.Abstractions.Boards
@using JustTaskTracker.WebUI.Services.Exceptions
@inject IBoardStore BoardStore
@inject IBoardApiService BoardApiService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Boards — JustTaskTracker</PageTitle>

<div class="boards">
    <section class="boards__section">
        <header class="boards__header">
            <h2 class="text-section-title">Active boards</h2>
            <input class="boards__search-input"
                   type="search"
                   maxlength="40"
                   placeholder="Search boards by name"
                   value="@BoardStore.Active.SearchText"
                   @oninput="OnActiveSearchInputAsync" />
            <div class="boards__pager">
                <button type="button"
                        class="btn-noir"
                        disabled="@(BoardStore.Active.CurrentPage <= 1 || BoardStore.Active.IsLoading)"
                        @onclick="() => ChangeActivePageAsync(BoardStore.Active.CurrentPage - 1)">
                    <span>Prev</span>
                </button>
                <span class="text-meta-subtle">
                    Page @BoardStore.Active.CurrentPage of @(Math.Max(BoardStore.Active.Pagination.TotalPages, 1))
                </span>
                <button type="button"
                        class="btn-noir"
                        disabled="@(BoardStore.Active.CurrentPage >= Math.Max(BoardStore.Active.Pagination.TotalPages, 1) || BoardStore.Active.IsLoading)"
                        @onclick="() => ChangeActivePageAsync(BoardStore.Active.CurrentPage + 1)">
                    <span>Next</span>
                </button>
            </div>
        </header>

        <div class="boards__boards">
            @if (BoardStore.Active.IsLoading && BoardStore.Active.Boards.Count == 0)
            {
                <div class="page-state">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                </div>
            }
            else if (BoardStore.Active.ErrorMessage is { } activeError)
            {
                <div class="page-state">
                    <MudAlert Severity="Severity.Error">@activeError</MudAlert>
                </div>
            }
            else if (BoardStore.Active.Boards.Count == 0 && !CanCreateBoard)
            {
                <div class="page-state">
                    <p class="text-empty">You don't have any boards yet.</p>
                </div>
            }
            else
            {
                <div class="boards__grid">
                    @if (CanCreateBoard)
                    {
                        <CreateBoardCard OnClick="CreateBoardAsync" />
                    }

                    @foreach (var board in BoardStore.Active.Boards)
                    {
                        <BoardCard Board="board" OnClick="OpenBoard" />
                    }
                </div>
            }
        </div>
    </section>

    <hr class="boards__divider" />

    <section class="boards__section">
        <header class="boards__header">
            <h2 class="text-section-title">Archived boards</h2>
            <input class="boards__search-input"
                   type="search"
                   maxlength="40"
                   placeholder="Search boards by name"
                   value="@BoardStore.Archived.SearchText"
                   @oninput="OnArchivedSearchInputAsync" />
            <div class="boards__pager">
                <button type="button"
                        class="btn-noir"
                        disabled="@(BoardStore.Archived.CurrentPage <= 1 || BoardStore.Archived.IsLoading)"
                        @onclick="() => ChangeArchivedPageAsync(BoardStore.Archived.CurrentPage - 1)">
                    <span>Prev</span>
                </button>
                <span class="text-meta-subtle">
                    Page @BoardStore.Archived.CurrentPage of @(Math.Max(BoardStore.Archived.Pagination.TotalPages, 1))
                </span>
                <button type="button"
                        class="btn-noir"
                        disabled="@(BoardStore.Archived.CurrentPage >= Math.Max(BoardStore.Archived.Pagination.TotalPages, 1) || BoardStore.Archived.IsLoading)"
                        @onclick="() => ChangeArchivedPageAsync(BoardStore.Archived.CurrentPage + 1)">
                    <span>Next</span>
                </button>
            </div>
        </header>

        <div class="boards__boards">
            @if (BoardStore.Archived.IsLoading && BoardStore.Archived.Boards.Count == 0)
            {
                <div class="page-state">
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                </div>
            }
            else if (BoardStore.Archived.ErrorMessage is { } archivedError)
            {
                <div class="page-state">
                    <MudAlert Severity="Severity.Error">@archivedError</MudAlert>
                </div>
            }
            else if (BoardStore.Archived.Boards.Count == 0)
            {
                <div class="page-state">
                    <p class="text-empty">You don't have any archived boards.</p>
                </div>
            }
            else
            {
                <div class="boards__grid">
                    @foreach (var board in BoardStore.Archived.Boards)
                    {
                        <BoardCard Board="board" OnClick="OpenBoard" />
                    }
                </div>
            }
        </div>
    </section>
</div>

@code {
    private bool CanCreateBoard =>
        ProfileStore.Profile?.Roles.Any(r =>
            r.Equals("Admin", StringComparison.OrdinalIgnoreCase) ||
            r.Equals("User", StringComparison.OrdinalIgnoreCase)) ?? false;

    [Inject]
    private IProfileStore ProfileStore { get; set; } = default!;

    protected override void OnInitialized()
    {
        BoardStore.StateChanged += OnStoreStateChanged;
        ProfileStore.StateChanged += OnProfileStoreStateChanged;
    }

    protected override Task OnParametersSetAsync() =>
        TryRefreshBoardsAsync();

    private async Task TryRefreshBoardsAsync()
    {
        if (!ProfileStore.IsLoaded || ProfileStore.RequiresLogin)
            return;

        if (BoardStore.Active.IsLoading || BoardStore.Archived.IsLoading)
            return;

        await BoardStore.RefreshAsync();
    }

    private void OpenBoard(BoardLookupDto board) =>
        Navigation.NavigateTo($"/boards/{board.Id}");

    private Task ChangeActivePageAsync(int pageNumber) =>
        BoardStore.LoadActiveAsync(pageNumber);

    private Task ChangeArchivedPageAsync(int pageNumber) =>
        BoardStore.LoadArchivedAsync(pageNumber);

    private Task OnActiveSearchInputAsync(ChangeEventArgs e) =>
        BoardStore.SetActiveSearchAsync(e.Value?.ToString() ?? string.Empty);

    private Task OnArchivedSearchInputAsync(ChangeEventArgs e) =>
        BoardStore.SetArchivedSearchAsync(e.Value?.ToString() ?? string.Empty);

    private async Task CreateBoardAsync()
    {
        var dialog = await DialogService.ShowResourceFormAsync(
            "Create new board",
            "Create",
            CreateBoardForm.FormId,
            CreateBoardForm.Render());
        var result = await dialog.Result;

        if (result is not { Canceled: false, Data: string name })
            return;

        try
        {
            var board = await BoardApiService.CreateBoardAsync(name);

            Snackbar.Add($"Board \"{board.Name}\" created.", Severity.Success);
            Navigation.NavigateTo($"/boards/{board.Id}");
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
    }

    public void Dispose()
    {
        BoardStore.StateChanged -= OnStoreStateChanged;
        ProfileStore.StateChanged -= OnProfileStoreStateChanged;
    }

    private void OnStoreStateChanged() => InvokeAsync(StateHasChanged);

    private void OnProfileStoreStateChanged() =>
        InvokeAsync(async () =>
        {
            await TryRefreshBoardsAsync();
            StateHasChanged();
        });
}
