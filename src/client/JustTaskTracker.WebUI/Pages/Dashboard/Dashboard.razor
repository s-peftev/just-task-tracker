@page "/dashboard"
@attribute [Authorize]
@implements IDisposable
@using JustTaskTracker.WebUI.Infrastructure
@using JustTaskTracker.WebUI.Services.Exceptions
@inject IProfileStore ProfileStore
@inject IBoardStore BoardStore
@inject IBoardApiService BoardApiService
@inject IDialogService DialogService
@inject ISnackbar Snackbar
@inject NavigationManager Navigation

<PageTitle>Dashboard — JustTaskTracker</PageTitle>

@if (ProfileStore.IsLoading && !ProfileStore.IsLoaded)
{
    <div class="dashboard dashboard--center">
        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
    </div>
}
else if (ProfileStore.IsLoaded && ProfileStore.Profile is { } profile)
{
    <div class="dashboard">
        <div class="dashboard__sidebar">
            <AppSidebar Profile="profile" />
        </div>

        <section class="dashboard__content">
            <header class="dashboard__header">
                <h2 class="dashboard__title">Boards</h2>
                <div class="dashboard__pager">
                    <button type="button"
                            class="btn-noir"
                            disabled="@(BoardStore.CurrentPage <= 1 || BoardStore.IsLoading)"
                            @onclick="() => ChangePageAsync(BoardStore.CurrentPage - 1)">
                        <span>Prev</span>
                    </button>
                    <span class="dashboard__pager-info">
                        Page @BoardStore.CurrentPage of @(Math.Max(BoardStore.Pagination.TotalPages, 1))
                    </span>
                    <button type="button"
                            class="btn-noir"
                            disabled="@(BoardStore.CurrentPage >= Math.Max(BoardStore.Pagination.TotalPages, 1) || BoardStore.IsLoading)"
                            @onclick="() => ChangePageAsync(BoardStore.CurrentPage + 1)">
                        <span>Next</span>
                    </button>
                </div>
            </header>

            <div class="dashboard__boards">
                @if (BoardStore.IsLoading && BoardStore.Boards.Count == 0)
                {
                    <div class="dashboard__state">
                        <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
                    </div>
                }
                else if (BoardStore.ErrorMessage is { } error)
                {
                    <div class="dashboard__state">
                        <MudAlert Severity="Severity.Error">@error</MudAlert>
                    </div>
                }
                else if (BoardStore.Boards.Count == 0 && !CanCreateBoard)
                {
                    <div class="dashboard__state">
                        <p class="dashboard__empty">You don't have any boards yet.</p>
                    </div>
                }
                else
                {
                    <div class="dashboard__grid">
                        @if (CanCreateBoard)
                        {
                            <CreateBoardCard OnClick="CreateBoardAsync" />
                        }

                        @foreach (var board in BoardStore.Boards)
                        {
                            <BoardCard Board="board" OnClick="OpenBoard" />
                        }
                    </div>
                }
            </div>
        </section>
    </div>
}
else if (ProfileStore.ErrorMessage is { } profileError)
{
    <div class="dashboard dashboard--center">
        <MudAlert Severity="Severity.Error">@profileError</MudAlert>
    </div>
}

@code {
    private bool CanCreateBoard =>
        ProfileStore.Profile?.Roles.Any(r =>
            r.Equals("Admin", StringComparison.OrdinalIgnoreCase) ||
            r.Equals("User", StringComparison.OrdinalIgnoreCase)) ?? false;

    protected override void OnInitialized()
    {
        ProfileStore.StateChanged += OnStoreStateChanged;
        BoardStore.StateChanged += OnStoreStateChanged;
    }

    protected override async Task OnInitializedAsync()
    {
        await ProfileStore.EnsureLoadedAsync();

        if (ProfileStore.RequiresLogin)
            Navigation.NavigateTo("/login");
    }

    protected override async Task OnParametersSetAsync()
    {
        if (!ProfileStore.IsLoaded || ProfileStore.RequiresLogin)
            return;

        await BoardStore.RefreshAsync();
    }

    private void OpenBoard(BoardLookupDto board) =>
        Navigation.NavigateTo($"/boards/{board.Id}");

    private async Task ChangePageAsync(int pageNumber) =>
        await BoardStore.LoadAsync(pageNumber);

    private async Task CreateBoardAsync()
    {
        var parameters = new DialogParameters<BoardFormDialog>
        {
            { x => x.SubmitLabel, "Create" }
        };

        var options = new DialogOptions
        {
            CloseOnEscapeKey = true,
            MaxWidth = MaxWidth.ExtraSmall,
            FullWidth = true
        };

        var dialog = await DialogService.ShowAsync<BoardFormDialog>("Create board", parameters, options);
        var result = await dialog.Result;

        if (result is not { Canceled: false, Data: string name })
            return;

        try
        {
            var board = await BoardApiService.CreateBoardAsync(name);

            Snackbar.Add($"Board \"{board.Name}\" created.", Severity.Success);
            Navigation.NavigateTo($"/boards/{board.Id}");
        }
        catch (ApiServiceException ex)
        {
            Snackbar.ShowApiError(ex);
        }
    }

    public void Dispose()
    {
        ProfileStore.StateChanged -= OnStoreStateChanged;
        BoardStore.StateChanged -= OnStoreStateChanged;
    }

    private void OnStoreStateChanged() => InvokeAsync(StateHasChanged);
}
