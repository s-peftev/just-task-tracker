@page "/not-found"
@layout MainLayout

<PageTitle>Not Found — JustTaskTracker</PageTitle>

<section class="not-found-scene" aria-label="Page not found">
    <div class="card-surface-grain not-found-card">
        <MudText Typo="Typo.h5" Style="margin-bottom: 0.25rem;">
            Not Found
        </MudText>
        <MudText Typo="Typo.body2" Style="color: rgba(255,255,255,0.55);">
            Sorry, the content you are looking for does not exist.
        </MudText>
    </div>
</section>
